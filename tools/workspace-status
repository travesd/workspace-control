#!/usr/bin/env bash
set -euo pipefail

ROOT="${WORKSPACE_ROOT:-/workspace}"
WORK_ROOT="$ROOT/detection-platform-metal-work"
MODE="${1:---brief}"

case "$MODE" in
  --brief|"")
    active_lines=50
    worktree_lines=40
    ;;
  --full)
    active_lines=200
    worktree_lines=200
    ;;
  *)
    echo "usage: $0 [--brief|--full]" >&2
    exit 2
    ;;
esac

echo "# Workspace Status"
date -u +"Generated: %Y-%m-%d %H:%M:%SZ"
echo

if [ -f "$WORK_ROOT/ACTIVE.md" ]; then
  echo "## Active Work"
  sed -n "1,${active_lines}p" "$WORK_ROOT/ACTIVE.md"
  if [ "$MODE" = "--brief" ]; then
    echo
    echo "_Use \`tools/workspace-status --full\` for the expanded active-work listing._"
  fi
  echo
else
  echo "Missing ACTIVE.md at $WORK_ROOT/ACTIVE.md"
fi

if [ -f "$WORK_ROOT/SESSIONS.md" ]; then
  echo "## Session Summary"
  sed -n '/^## Summary/,/^## Live Recorded Sessions/p' "$WORK_ROOT/SESSIONS.md" | sed '$d'
  echo
fi

echo "## Current Directory"
pwd
echo

echo "## Worktrees"
if [ -d "$ROOT/detection-platform-metal" ]; then
  git -C "$ROOT/detection-platform-metal" worktree list --porcelain | awk '
    /^worktree / {wt=$0; sub(/^worktree /, "", wt); print "- " wt}
    /^branch / {print "  " $0}
  ' | sed -n "1,${worktree_lines}p"
  if [ "$MODE" = "--brief" ]; then
    echo
    echo "_Use \`tools/workspace-status --full\` for more worktrees._"
  fi
else
  echo "- detection-platform-metal repo not found"
fi

echo
echo "## Intake Checklist"
echo "- For non-trivial work, create or identify a task dir."
echo "- For branch work, use a detection-platform-metal worktree."
echo "- Record long-running agent sessions in task resume.md."
echo "- Keep data products in /workspace/datasets, not task dirs."
