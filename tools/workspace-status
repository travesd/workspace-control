#!/usr/bin/env bash
set -euo pipefail

ROOT="${WORKSPACE_ROOT:-/workspace}"
CONTROL_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
WORK_ROOT="$ROOT/detection-platform-metal-work"
MODE="${1:---brief}"

count_state() {
  local name="$1"
  local path="$WORK_ROOT/$name"
  if [ ! -d "$path" ]; then
    echo 0
    return
  fi
  if [ "$name" = "planned" ]; then
    find "$path" -mindepth 1 -maxdepth 1 \( -type d -o -name '*.md' \) ! -name README.md | wc -l
  else
    find "$path" -mindepth 1 -maxdepth 1 -type d | wc -l
  fi
}

case "$MODE" in
  --brief|"")
    active_lines=50
    worktree_lines=40
    ;;
  --full)
    active_lines=200
    worktree_lines=200
    ;;
  *)
    echo "usage: $0 [--brief|--full]" >&2
    exit 2
    ;;
esac

echo "# Workspace Status"
date -u +"Generated: %Y-%m-%d %H:%M:%SZ"
echo

if [ -f "$WORK_ROOT/ACTIVE.md" ]; then
  echo "## Active Work"
  sed -n "1,${active_lines}p" "$WORK_ROOT/ACTIVE.md"
  if [ "$MODE" = "--brief" ]; then
    echo
    echo "_Use \`tools/workspace-status --full\` for the expanded active-work listing._"
  fi
  echo
else
  echo "Missing ACTIVE.md at $WORK_ROOT/ACTIVE.md"
fi

if [ -f "$WORK_ROOT/SESSIONS.md" ]; then
  echo "## Session Summary"
  sed -n '/^## Summary/,/^## Live Recorded Sessions/p' "$WORK_ROOT/SESSIONS.md" | sed '$d'
  echo
fi

echo "## Knowledge Health"
if [ -d "$CONTROL_ROOT/knowledge" ] && [ -x "$CONTROL_ROOT/tools/knowledgectl" ]; then
  note_count="$(find "$CONTROL_ROOT/knowledge" -maxdepth 1 -type f -name '*.md' ! -name INDEX.md ! -name README.md ! -name TEMPLATE.md | wc -l)"
  stale_line="$("$CONTROL_ROOT/tools/knowledgectl" stale | tail -n 1 || true)"
  stale_count="${stale_line#stale_candidates=}"
  if "$CONTROL_ROOT/tools/knowledgectl" index --check >/dev/null 2>&1; then
    index_state="fresh"
  else
    index_state="stale"
  fi
  echo "- notes: $note_count"
  echo "- stale candidates: ${stale_count:-unknown}"
  echo "- generated index: $index_state"
  echo "- index path: $CONTROL_ROOT/knowledge/INDEX.md"
else
  echo "- knowledge tooling unavailable"
fi
echo

echo "## Task State Counts"
for name in busy parked planned later done archived investigations; do
  printf -- "- %s: %s\n" "$name" "$(count_state "$name")"
done
echo

echo "## Current Directory"
pwd
echo

echo "## Worktrees"
if [ -d "$ROOT/detection-platform-metal" ]; then
  git -C "$ROOT/detection-platform-metal" worktree list --porcelain | awk '
    /^worktree / {wt=$0; sub(/^worktree /, "", wt); print "- " wt}
    /^branch / {print "  " $0}
  ' | sed -n "1,${worktree_lines}p"
  if [ "$MODE" = "--brief" ]; then
    echo
    echo "_Use \`tools/workspace-status --full\` for more worktrees._"
  fi
else
  echo "- detection-platform-metal repo not found"
fi

echo
echo "## Intake Checklist"
echo "- For non-trivial work, create or identify a task dir."
echo "- For branch work, use a detection-platform-metal worktree."
echo "- Record long-running agent sessions in task resume.md."
echo "- Keep data products in /workspace/datasets, not task dirs."
