#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
TOOL="$ROOT/tools/workflowctl"
TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

echo "# workflowctl self-test"

"$TOOL" --help >/dev/null
"$TOOL" classify --task-path "$ROOT/docs/research/2026-05-26-implementation-automation-overhaul" >/dev/null

"$TOOL" init \
  --task-path "$TMPDIR/task" \
  --kind llm-eval \
  --repo workspace-control \
  --request "workflowctl self-test" >/dev/null

cat > "$TMPDIR/task/resume.md" <<EOF
# Resume

## Current State

- **Branch:** \`self-test-branch\`
- **Worktree:** \`$ROOT\`
- pnpm validate GREEN.

## Validation Plan

\`\`\`bash
git diff --check
./tools/workflowctl-selftest
\`\`\`

EOF

test -f "$TMPDIR/task/workflow.json"
test -f "$TMPDIR/task/validation.jsonl"
jq empty "$TMPDIR/task/workflow.json"
jq -s empty "$TMPDIR/task/validation.jsonl"
test "$(jq -c '.task.related_tasks' "$TMPDIR/task/workflow.json")" = "[]"

"$TOOL" hydrate --task-path "$TMPDIR/task" >/dev/null
test "$(jq -r '.task.branch' "$TMPDIR/task/workflow.json")" = "self-test-branch"
test "$(jq -r '.task.worktree' "$TMPDIR/task/workflow.json")" = "$ROOT"
test "$(jq '.preflight.validation_plan | length' "$TMPDIR/task/workflow.json")" -eq 2

"$TOOL" validation import --task-path "$TMPDIR/task" >/dev/null
if "$TOOL" validate --task-path "$TMPDIR/task" >/dev/null 2>&1; then
  echo "expected historical-only validation import not to pass validate" >&2
  exit 1
fi

"$TOOL" validation add \
  --task-path "$TMPDIR/task" \
  --command "git diff --check" \
  --result pass \
  --evidence "self-test" >/dev/null
"$TOOL" validate --task-path "$TMPDIR/task" >/dev/null

if "$TOOL" experiment check --task-path "$TMPDIR/task" >/dev/null 2>&1; then
  echo "expected experiment check to fail before contract init" >&2
  exit 1
fi

"$TOOL" experiment init \
  --task-path "$TMPDIR/task" \
  --mutable "prompts/program.md" \
  --sealed-evaluator "fixtures/eval.jsonl" \
  --budget "3 runs" \
  --metric "accuracy" \
  --keep-rule "keep if metric improves without complexity increase" >/dev/null
"$TOOL" experiment check --task-path "$TMPDIR/task" >/dev/null
"$TOOL" experiment record \
  --task-path "$TMPDIR/task" \
  --status keep \
  --candidate self-test-candidate \
  --metric "accuracy=1.0" \
  --evidence "self-test" >/dev/null

"$TOOL" context-pack --task-path "$TMPDIR/task" --max-bytes 2000 >/dev/null
test -d "$TMPDIR/task/artifacts"
find "$TMPDIR/task/artifacts" -type f -name 'context-pack-*.md' | grep -q .
test "$(jq -r '.stage_artifacts.context_pack' "$TMPDIR/task/workflow.json")" != ""

"$TOOL" gate init \
  --task-path "$TMPDIR/task" \
  --scope-bucket standard \
  --decision promote-to-implementation >/dev/null
if "$TOOL" gate check --task-path "$TMPDIR/task" >/dev/null 2>&1; then
  echo "expected gate check to fail before promotion evidence is recorded" >&2
  exit 1
fi

cat > "$TMPDIR/task/implementation-brief.md" <<EOF
# Implementation Brief

## Goal

Exercise the workflowctl gate and swarm contract.
EOF

"$TOOL" gate record \
  --task-path "$TMPDIR/task" \
  --decision promote-to-implementation \
  --scope-bucket standard \
  --brief "$TMPDIR/task/implementation-brief.md" \
  --goal "exercise workflowctl gate and swarm contract" \
  --source-read "tools/workflowctl,tools/workflowctl-selftest" \
  --write-scope "tools/workflowctl,docs/reference/workflowctl.md" \
  --sealed-surface "tools/workflowctl-selftest" \
  --validation "git diff --check,./tools/workflowctl-selftest" >/dev/null
"$TOOL" gate check --task-path "$TMPDIR/task" >/dev/null

"$TOOL" swarm init \
  --task-path "$TMPDIR/task" \
  --decision parallel-read \
  --loop-cap "2 blocker review loops" >/dev/null
if "$TOOL" swarm check --task-path "$TMPDIR/task" >/dev/null 2>&1; then
  echo "expected swarm check to fail before lane assignment" >&2
  exit 1
fi
"$TOOL" swarm assign \
  --task-path "$TMPDIR/task" \
  --lane A \
  --role source-read \
  --task "review workflowctl contract shape" \
  --sealed "tools/workflowctl,docs/reference/workflowctl.md" \
  --preflight "context pack read" \
  --handoff "$TMPDIR/task/artifacts/swarm/A-handoff.md" >/dev/null
"$TOOL" swarm check --task-path "$TMPDIR/task" >/dev/null
"$TOOL" swarm record \
  --task-path "$TMPDIR/task" \
  --lane A \
  --status complete \
  --handoff "$TMPDIR/task/artifacts/swarm/A-handoff.md" \
  --evidence "self-test" >/dev/null

"$TOOL" init \
  --task-path "$TMPDIR/impl" \
  --kind implementation \
  --repo workspace-control \
  --request "workflowctl parallel implement self-test" >/dev/null
"$TOOL" swarm init \
  --task-path "$TMPDIR/impl" \
  --decision parallel-implement \
  --loop-cap "1 integration loop" >/dev/null
"$TOOL" swarm assign \
  --task-path "$TMPDIR/impl" \
  --lane A \
  --role implementation \
  --task "edit first surface" \
  --mutable "tools/workflowctl" \
  --sealed "tools/workflowctl-selftest" \
  --preflight "context pack read" >/dev/null
"$TOOL" swarm assign \
  --task-path "$TMPDIR/impl" \
  --lane B \
  --role implementation \
  --task "edit overlapping surface" \
  --mutable "tools/workflowctl" \
  --sealed "docs/reference/workflowctl.md" \
  --preflight "context pack read" >/dev/null
if "$TOOL" swarm check --task-path "$TMPDIR/impl" >/dev/null 2>&1; then
  echo "expected swarm check to fail for overlapping implementation surfaces" >&2
  exit 1
fi
"$TOOL" swarm assign \
  --task-path "$TMPDIR/impl" \
  --lane B \
  --role implementation \
  --task "edit second surface" \
  --mutable "docs/reference/workflowctl.md" \
  --sealed "tools/workflowctl-selftest" \
  --preflight "context pack read" >/dev/null
"$TOOL" swarm check --task-path "$TMPDIR/impl" >/dev/null

"$TOOL" export --task-path "$TMPDIR/task" --format pi-workflow > "$TMPDIR/pi-workflow.json"
jq empty "$TMPDIR/pi-workflow.json"
"$TOOL" export --task-path "$TMPDIR/task" --format agentic-runbook > "$TMPDIR/runbook.md"
test -s "$TMPDIR/runbook.md"
"$TOOL" export --task-path "$TMPDIR/task" --format swarm-runbook > "$TMPDIR/swarm-runbook.md"
test -s "$TMPDIR/swarm-runbook.md"

"$TOOL" metrics --root /workspace/detection-platform-metal-work >/dev/null

if "$TOOL" close-check --task-path "$TMPDIR/task" >/dev/null 2>&1; then
  echo "expected close-check to fail without resume/SUMMARY" >&2
  exit 1
fi

echo "workflowctl self-test: pass"
