#!/usr/bin/env bash
set -euo pipefail

ROOT="${WORKSPACE_ROOT:-/workspace}"
CONTROL_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
WORK_ROOT="$ROOT/detection-platform-metal-work"

count_dirs() {
  local path="$1"
  if [ -d "$path" ]; then
    find "$path" -mindepth 1 -maxdepth 1 -type d | wc -l
  else
    echo 0
  fi
}

count_state() {
  local name="$1"
  local path="$WORK_ROOT/$name"
  if [ ! -d "$path" ]; then
    echo 0
    return
  fi
  if [ "$name" = "planned" ]; then
    find "$path" -mindepth 1 -maxdepth 1 \( -type d -o -name '*.md' \) ! -name README.md | wc -l
  else
    count_dirs "$path"
  fi
}

print_knowledge_inventory() {
  local label="$1"
  local dir="$2"
  echo "## $label"
  if [ -d "$dir" ]; then
    echo "- notes: $(find "$dir" -maxdepth 1 -type f -name '*.md' ! -name INDEX.md ! -name README.md ! -name TEMPLATE.md | wc -l)"
    if [ -x "$CONTROL_ROOT/tools/knowledgectl" ]; then
      KNOWLEDGE_DIR="$dir" "$CONTROL_ROOT/tools/knowledgectl" stale | tail -n 1 | sed 's/^/- /'
      if KNOWLEDGE_DIR="$dir" "$CONTROL_ROOT/tools/knowledgectl" index --check >/dev/null 2>&1; then
        echo "- generated index: fresh"
      else
        echo "- generated index: stale"
      fi
    fi
  else
    echo "- unavailable: $dir"
  fi
  echo
}

echo "# Workspace Artifact Inventory"
date -u +"Generated: %Y-%m-%d %H:%M:%SZ"
echo

echo "## Task Directories"
for name in busy parked planned later done archived investigations; do
  printf -- "- %s: %s\\n" "$name" "$(count_state "$name")"
done
echo

echo "## Resume Files"
if [ -d "$WORK_ROOT/busy" ]; then
  echo "- busy dirs: $(find "$WORK_ROOT/busy" -mindepth 1 -maxdepth 1 -type d | wc -l)"
  echo "- resume files: $(find "$WORK_ROOT/busy" -mindepth 2 -maxdepth 2 -name resume.md | wc -l)"
  echo "- missing resume:"
  find "$WORK_ROOT/busy" -mindepth 1 -maxdepth 1 -type d ! -exec test -e '{}/resume.md' \; -print | sed 's/^/  - /' || true
fi
echo

echo "## Worktrees"
if [ -d "$ROOT/detection-platform-metal" ]; then
  git -C "$ROOT/detection-platform-metal" worktree list --porcelain | grep -c '^worktree ' | sed 's/^/- count: /'
fi
echo

echo "## Dataset And Backup Manifests"
echo "- dataset manifests: $(find "$ROOT/datasets" -type f \( -name MANIFEST.json -o -name SNAPSHOT.md \) 2>/dev/null | wc -l)"
echo "- backup manifests: $(find "$ROOT/backups" -type f -name MANIFEST.json 2>/dev/null | wc -l)"
echo

echo "## Live Shared Skills"
if [ -d "$ROOT/agent-skills/skills" ]; then
  find "$ROOT/agent-skills/skills" -mindepth 1 -maxdepth 1 -type d -printf '- %f\n' | sort
fi
echo

echo "## Workspace-Control Skills"
if [ -d "$CONTROL_ROOT/agent-skills/skills" ]; then
  find "$CONTROL_ROOT/agent-skills/skills" -mindepth 1 -maxdepth 1 -type d -printf '- %f\n' | sort
fi
echo

print_knowledge_inventory "Workspace-Control Knowledge" "$CONTROL_ROOT/knowledge"
print_knowledge_inventory "Detection-Platform-Metal Workspace Knowledge" "$WORK_ROOT/knowledge"

echo "## Large Busy Task Dirs"
if [ -d "$WORK_ROOT/busy" ]; then
  du -sh "$WORK_ROOT/busy"/* 2>/dev/null | sort -hr | sed -n '1,20p'
fi
