cmd_preflight() {
  need_jq
  local task_path="" workflow_file repo kind worktree validation_count root
  local blockers=() warnings=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown preflight argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "preflight requires --task-path"
  workflow_file="$(workflow_file_for "$task_path")"

  [ -d "$task_path" ] || blockers+=("task path does not exist")
  [ -f "$WORKSPACE_ROOT/AGENTS.md" ] || blockers+=("active workspace instructions missing at $WORKSPACE_ROOT/AGENTS.md")
  [ -f "$CONTROL_ROOT/docs/specs/implementation-automation-kernel.md" ] || blockers+=("kernel spec missing")
  if [ ! -f "$workflow_file" ]; then
    blockers+=("workflow.json missing; run workflowctl init first")
  else
    jq empty "$workflow_file" >/dev/null || blockers+=("workflow.json is invalid JSON")
    repo="$(read_workflow_field "$workflow_file" '.task.repo' "")"
    kind="$(read_workflow_field "$workflow_file" '.classification.kind' "")"
    worktree="$(read_workflow_field "$workflow_file" '.task.worktree' "")"
    validation_count="$(jq '.preflight.validation_plan // [] | length' "$workflow_file")"
    [ "$(read_workflow_field "$workflow_file" '.schema' "")" = "$SCHEMA" ] || blockers+=("workflow schema is not $SCHEMA")
    [ -n "$repo" ] && valid_repo "$repo" || blockers+=("task.repo is missing or invalid")
    [ -n "$kind" ] && valid_kind "$kind" || blockers+=("classification.kind is missing or invalid")
    [ "$validation_count" -gt 0 ] || blockers+=("preflight.validation_plan is empty")
    if [ -n "$worktree" ] && [ ! -d "$worktree" ]; then
      blockers+=("declared worktree does not exist: $worktree")
    fi
    case "$repo:$kind" in
      detection-platform-metal:implementation|detection-agentic-workflows:implementation)
        [ -n "$worktree" ] || blockers+=("implementation task is missing task.worktree")
        ;;
    esac
  fi

  [ -f "$task_path/resume.md" ] || warnings+=("resume.md missing")
  root="$(task_root_for_path "$task_path")"
  if [ -n "$root" ] && [ ! -f "$root/SESSIONS.md" ]; then
    warnings+=("task root has no SESSIONS.md: $root")
  fi

  echo "# Workflow Preflight"
  echo "- task_path: $task_path"
  echo "- active_rules: $([ -f "$WORKSPACE_ROOT/AGENTS.md" ] && echo present || echo missing)"
  echo "- kernel_spec: $([ -f "$CONTROL_ROOT/docs/specs/implementation-automation-kernel.md" ] && echo present || echo missing)"
  echo
  echo "## Warnings"
  if [ "${#warnings[@]}" -eq 0 ]; then
    echo "- none"
  else
    printf -- "- %s\n" "${warnings[@]}"
  fi
  echo
  echo "## Blockers"
  if [ "${#blockers[@]}" -eq 0 ]; then
    echo "- none"
    return 0
  fi
  printf -- "- %s\n" "${blockers[@]}"
  return 1
}

cmd_validate() {
  need_jq
  local task_path="" ledger_file entries failures blocked passes historical skipped
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown validate argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "validate requires --task-path"
  ledger_file="$(ledger_file_for "$task_path")"

  echo "# Validation Ledger"
  echo "- task_path: $task_path"
  echo "- validation_ledger: $ledger_file"
  if [ ! -f "$ledger_file" ]; then
    echo
    echo "## Blockers"
    echo "- validation.jsonl missing"
    return 1
  fi
  jq -s empty "$ledger_file" >/dev/null
  entries="$(jq -s '[.[] | select(.type == "validation")] | length' "$ledger_file")"
  passes="$(jq -s '[.[] | select(.type == "validation" and .result == "pass")] | length' "$ledger_file")"
  failures="$(jq -s '[.[] | select(.type == "validation" and .result == "fail")] | length' "$ledger_file")"
  blocked="$(jq -s '[.[] | select(.type == "validation" and .result == "blocked")] | length' "$ledger_file")"
  skipped="$(jq -s '[.[] | select(.type == "validation" and .result == "skipped")] | length' "$ledger_file")"
  historical="$(jq -s '[.[] | select(.type == "validation" and .historical == true)] | length' "$ledger_file")"
  echo "- validation_entries: $entries"
  echo "- passing_entries: $passes"
  echo "- historical_entries: $historical"
  echo
  echo "## Results"
  jq -r -s '
    [.[] | select(.type == "validation")]
    | if length == 0 then "- none"
      else group_by(.result // "missing")
        | map("- " + (.[0].result // "missing") + ": " + (length|tostring))
        | .[]
      end
  ' "$ledger_file"
  if [ "$entries" -eq 0 ] || [ "$passes" -eq 0 ] || [ "$failures" -gt 0 ] || [ "$blocked" -gt 0 ]; then
    echo
    echo "## Blockers"
    [ "$entries" -gt 0 ] || echo "- no validation entries recorded"
    [ "$passes" -gt 0 ] || echo "- no passing validation entries recorded"
    [ "$failures" -eq 0 ] || echo "- failing validation entries recorded"
    [ "$blocked" -eq 0 ] || echo "- blocked validation entries recorded"
    [ "$skipped" -eq 0 ] || echo "- skipped entries do not count as fresh validation passes"
    return 1
  fi
}

cmd_context_pack() {
  need_jq
  local task_path="" output="" max_bytes=12000 workflow_file ledger_file experiment_file worktree tmp
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      --output) output="${2:-}"; shift 2 ;;
      --max-bytes) max_bytes="${2:-}"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown context-pack argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "context-pack requires --task-path"
  [ -d "$task_path" ] || die "task path does not exist: $task_path"
  case "$max_bytes" in
    ''|*[!0-9]*) die "--max-bytes must be a positive integer" ;;
  esac
  [ "$max_bytes" -gt 0 ] || die "--max-bytes must be greater than zero"

  if [ -z "$output" ]; then
    mkdir -p "$task_path/artifacts"
    output="$task_path/artifacts/context-pack-$(date -u +%Y%m%dT%H%M%SZ).md"
  elif [ "$output" != "-" ]; then
    output="$(normalize_path "$output")"
    case "$output" in
      "$task_path"/*) mkdir -p "$(dirname "$output")" ;;
      *) die "--output must be under --task-path or '-' for stdout" ;;
    esac
  fi

  workflow_file="$(workflow_file_for "$task_path")"
  ledger_file="$(ledger_file_for "$task_path")"
  experiment_file="$(experiment_file_for "$task_path")"
  if [ "$output" != "-" ] && [ -f "$workflow_file" ]; then
    tmp="$(mktemp)"
    jq --arg output "$output" '.surfaces.context_pack = $output' "$workflow_file" > "$tmp"
    mv "$tmp" "$workflow_file"
  fi
  tmp="$(mktemp)"
  {
    echo "# Workflow Context Pack"
    echo
    echo "- generated: $(now_utc)"
    echo "- task_path: $task_path"
    echo "- workflow: $([ -f "$workflow_file" ] && echo present || echo missing)"
    echo "- validation_ledger: $([ -f "$ledger_file" ] && echo present || echo missing)"
    echo "- experiment_ledger: $([ -f "$experiment_file" ] && echo present || echo missing)"
    if [ -f "$workflow_file" ]; then
      jq empty "$workflow_file" >/dev/null
      echo
      echo "## Workflow Summary"
      echo
      jq -r '
        "- request: \(.task.request // "missing")",
        "- repo: \(.task.repo // "missing")",
        "- kind: \(.classification.kind // "missing")",
        "- complexity: \(.classification.complexity // "missing")",
        "- automation: \(.mode.automation // "missing")",
        "- risk: \((.classification.risk // []) | join(","))",
        "- thinking: \((.mode.thinking // []) | join(","))",
        "- checkpoints: \((.mode.human_checkpoints // []) | join(","))"
      ' "$workflow_file"
      worktree="$(read_workflow_field "$workflow_file" '.task.worktree' "")"
      if [ -n "$worktree" ] && [ -d "$worktree" ]; then
        echo
        echo "## Worktree"
        echo
        echo "- path: $worktree"
        if git -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
          echo
          echo '```text'
          git -C "$worktree" status --short
          git -C "$worktree" diff --stat
          echo '```'
        else
          echo "- not a git worktree"
        fi
      fi
    fi

    echo
    echo "## Task Files"
    emit_file_excerpt "resume.md" "$task_path/resume.md" "$max_bytes"
    emit_file_excerpt "SUMMARY.md" "$task_path/SUMMARY.md" "$max_bytes"
    emit_file_excerpt "notes.md" "$task_path/notes.md" "$max_bytes"
    emit_file_excerpt "LINEAGE.md" "$task_path/LINEAGE.md" "$max_bytes"
    emit_file_excerpt "workflow.json" "$workflow_file" "$max_bytes"
    emit_file_excerpt "validation.jsonl" "$ledger_file" "$max_bytes"
    emit_file_excerpt "experiment.jsonl" "$experiment_file" "$max_bytes"
  } > "$tmp"

  if [ "$output" = "-" ]; then
    cat "$tmp"
    rm -f "$tmp"
  else
    mv "$tmp" "$output"
    echo "# Context Pack Written"
    echo "- task_path: $task_path"
    echo "- output: $output"
  fi
}

cmd_experiment_init() {
