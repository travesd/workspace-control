#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if CONTROL_ROOT="$(git -C "$SCRIPT_DIR/.." rev-parse --show-toplevel 2>/dev/null)"; then
  :
else
  CONTROL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
fi
WORKSPACE_ROOT="${WORKSPACE_ROOT:-/workspace}"
SCHEMA="workspace-control.implementation-workflow.v0"
LEDGER_SCHEMA="workspace-control.validation-ledger.v0"
EXPERIMENT_SCHEMA="workspace-control.experiment-ledger.v0"

usage() {
  cat <<'USAGE'
usage:
  tools/workflowctl init --task-path <path> [--kind <kind>] [--repo <repo>] [--request <text>] [--force]
  tools/workflowctl classify --task-path <path>
  tools/workflowctl hydrate --task-path <path> [--source <resume.md>]
  tools/workflowctl preflight --task-path <path>
  tools/workflowctl status --task-path <path>
  tools/workflowctl validation add --task-path <path> --command <text> --result <result> [--package <id>] [--cwd <path>] [--evidence <text>] [--notes <text>]
  tools/workflowctl validation import --task-path <path> [--source <resume.md>] [--package <id>]
  tools/workflowctl validate --task-path <path>
  tools/workflowctl context-pack --task-path <path> [--output <path>|-] [--max-bytes <n>]
  tools/workflowctl experiment init --task-path <path> --mutable <csv> --sealed-evaluator <csv> --budget <text> --metric <text> --keep-rule <text> [--complexity-delta <text>]
  tools/workflowctl experiment check --task-path <path>
  tools/workflowctl experiment record --task-path <path> --status keep|discard|crash [--candidate <id>] [--metric <text>] [--evidence <text>] [--complexity-delta <text>] [--notes <text>]
  tools/workflowctl export --task-path <path> --format pi-workflow|agentic-runbook
  tools/workflowctl metrics [--root <path>]
  tools/workflowctl close-check --task-path <path>

Kinds:
  implementation, review, investigation, dataset, operating-model, llm-eval, closeoff

Repos:
  workspace-control, detection-platform-metal, detection-agentic-workflows, cross-repo

The MVP is host-safe. Write commands only write under the selected task path and
never run product tests, push, open PRs, or activate live files.
USAGE
}

die() {
  echo "workflowctl: $*" >&2
  exit 2
}

need_jq() {
  command -v jq >/dev/null 2>&1 || die "jq is required"
}

now_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

normalize_path() {
  local path="$1"
  case "$path" in
    /*) printf '%s\n' "$path" ;;
    *) printf '%s/%s\n' "$(pwd)" "$path" ;;
  esac
}

lower_text() {
  tr '[:upper:]' '[:lower:]'
}

unique_csv() {
  local seen="" item out=""
  IFS=',' read -r -a items <<< "${1:-}"
  for item in "${items[@]}"; do
    [ -n "$item" ] || continue
    case ",$seen," in
      *,"$item",*) ;;
      *)
        seen="${seen:+$seen,}$item"
        out="${out:+$out,}$item"
        ;;
    esac
  done
  printf '%s\n' "$out"
}

infer_repo() {
  local path="$1"
  case "$path" in
    "$CONTROL_ROOT"|"$CONTROL_ROOT"/*) echo "workspace-control" ;;
    "$WORKSPACE_ROOT/detection-agentic-workflows"|"$WORKSPACE_ROOT/detection-agentic-workflows"/*|"$WORKSPACE_ROOT/detection-agentic-workflows.worktrees"/*|"$WORKSPACE_ROOT/detection-agentic-workflows-work"/*) echo "detection-agentic-workflows" ;;
    "$WORKSPACE_ROOT/detection-platform-metal"|"$WORKSPACE_ROOT/detection-platform-metal"/*|"$WORKSPACE_ROOT/detection-platform-metal.worktrees"/*|"$WORKSPACE_ROOT/detection-platform-metal-work"/*) echo "detection-platform-metal" ;;
    "$WORKSPACE_ROOT"/*) echo "cross-repo" ;;
    *) echo "workspace-control" ;;
  esac
}

valid_repo() {
  case "$1" in
    workspace-control|detection-platform-metal|detection-agentic-workflows|cross-repo) return 0 ;;
    *) return 1 ;;
  esac
}

valid_kind() {
  case "$1" in
    implementation|review|investigation|dataset|operating-model|llm-eval|closeoff) return 0 ;;
    *) return 1 ;;
  esac
}

valid_validation_result() {
  case "$1" in
    pass|fail|skipped|blocked) return 0 ;;
    *) return 1 ;;
  esac
}

valid_experiment_status() {
  case "$1" in
    keep|discard|crash) return 0 ;;
    *) return 1 ;;
  esac
}

infer_request() {
  local path="$1"
  local base
  base="$(basename "$path")"
  base="${base//-/ }"
  base="${base//_/ }"
  printf '%s\n' "$base"
}

infer_kind() {
  local path="$1"
  local request="${2:-}"
  local text
  text="$(printf '%s %s' "$path" "$request" | lower_text)"

  case "$text" in
    *llm*|*eval*|*classifier*|*prompt*|*ground-truth*|*ground_truth*) echo "llm-eval" ;;
    *dataset*|*export*|*corpus*) echo "dataset" ;;
    *closeoff*|*close-off*|*close\ off*|*archive*|*cleanup*) echo "closeoff" ;;
    *review*|*audit*|*pr-*) echo "review" ;;
    *investigat*|*research*|*trace*|*diagnos*) echo "investigation" ;;
    *workspace-control*|*workflow*|*agent*|*skill*|*instruction*|*operating-model*|*automation-kernel*) echo "operating-model" ;;
    *) echo "implementation" ;;
  esac
}

infer_complexity() {
  local kind="$1"
  case "$kind" in
    closeoff) echo "clear" ;;
    llm-eval) echo "complex" ;;
    operating-model|dataset|investigation|review|implementation) echo "complicated" ;;
    *) echo "complicated" ;;
  esac
}

infer_risk_csv() {
  local repo="$1" kind="$2" path="$3"
  local text risks=""
  text="$(printf '%s' "$path" | lower_text)"

  [ "$repo" = "workspace-control" ] && risks="${risks:+$risks,}workspace-rules"
  [ "$repo" = "detection-platform-metal" ] && risks="${risks:+$risks,}product-code"
  [ "$repo" = "detection-agentic-workflows" ] && risks="${risks:+$risks,}agentic-workflow"
  [ "$repo" = "cross-repo" ] && risks="${risks:+$risks,}cross-repo"
  [ "$kind" = "dataset" ] && risks="${risks:+$risks,}data-product"
  [ "$kind" = "llm-eval" ] && risks="${risks:+$risks,}llm-quality"
  case "$text" in
    *prod*|*production*|*db*) risks="${risks:+$risks,}production-read-risk" ;;
  esac

  unique_csv "$risks"
}

infer_thinking_csv() {
  local kind="$1"
  case "$kind" in
    closeoff) echo "recognition" ;;
    operating-model) echo "systems-leverage,divergent-convergent" ;;
    investigation) echo "divergent-convergent,deliberate-engineering" ;;
    llm-eval) echo "experimental-complex-systems" ;;
    review|dataset|implementation) echo "deliberate-engineering" ;;
    *) echo "deliberate-engineering" ;;
  esac
}

infer_automation() {
  local kind="$1"
  case "$kind" in
    closeoff) echo "checklist" ;;
    *) echo "deterministic-workflow" ;;
  esac
}

infer_checkpoints_csv() {
  local repo="$1" risk_csv="$2"
  local checkpoints="before-push,before-pr"
  [ "$repo" = "workspace-control" ] && checkpoints="$checkpoints,before-live-activation"
  case ",$risk_csv," in
    *,data-product,*) checkpoints="$checkpoints,before-dataset-publish" ;;
  esac
  unique_csv "$checkpoints"
}

infer_validation_plan_csv() {
  local repo="$1" kind="$2"
  case "$repo:$kind" in
    workspace-control:*)
      echo "./tools/check-sensitive-content .,git diff --check,./tools/knowledgectl index --check"
      ;;
    detection-platform-metal:implementation|detection-platform-metal:dataset|detection-platform-metal:llm-eval)
      echo "container/local-stack validation required,record command output in validation.jsonl"
      ;;
    detection-agentic-workflows:*)
      echo "docker compose run --rm agentic pnpm <tool>,record JSON-envelope artifacts"
      ;;
    *)
      echo "source-read evidence required,record validation evidence"
      ;;
  esac
}

task_root_for_path() {
  local path="$1"
  case "$path" in
    "$WORKSPACE_ROOT/detection-platform-metal-work"/*) echo "$WORKSPACE_ROOT/detection-platform-metal-work" ;;
    "$WORKSPACE_ROOT/detection-agentic-workflows-work"/*) echo "$WORKSPACE_ROOT/detection-agentic-workflows-work" ;;
    *) echo "" ;;
  esac
}

infer_worktree_from_branch() {
  local repo="$1" branch="$2" branch_dir root candidate
  [ -n "$branch" ] || return 1
  branch_dir="${branch//\//-}"
  case "$repo" in
    detection-platform-metal) root="$WORKSPACE_ROOT/detection-platform-metal.worktrees" ;;
    detection-agentic-workflows) root="$WORKSPACE_ROOT/detection-agentic-workflows.worktrees" ;;
    *) return 1 ;;
  esac
  candidate="$root/$branch_dir"
  [ -d "$candidate" ] || return 1
  printf '%s\n' "$candidate"
}

workflow_file_for() {
  printf '%s/workflow.json\n' "$1"
}

ledger_file_for() {
  printf '%s/validation.jsonl\n' "$1"
}

experiment_file_for() {
  printf '%s/experiment.jsonl\n' "$1"
}

ensure_ledger() {
  local task_path="$1"
  local ledger_file
  ledger_file="$(ledger_file_for "$task_path")"
  if [ ! -f "$ledger_file" ]; then
    printf '{"schema":"%s","type":"header","task_path":"%s","created":"%s"}\n' "$LEDGER_SCHEMA" "$task_path" "$(now_utc)" > "$ledger_file"
  fi
}

ensure_experiment_ledger() {
  local task_path="$1"
  local experiment_file
  experiment_file="$(experiment_file_for "$task_path")"
  if [ ! -f "$experiment_file" ]; then
    printf '{"schema":"%s","type":"header","task_path":"%s","created":"%s"}\n' "$EXPERIMENT_SCHEMA" "$task_path" "$(now_utc)" > "$experiment_file"
  fi
}

read_workflow_field() {
  local workflow_file="$1" filter="$2" fallback="${3:-}"
  jq -r --arg fallback "$fallback" "($filter) // \$fallback" "$workflow_file"
}

extract_resume_json() {
  local source="$1"
  perl -Mstrict -Mwarnings -MJSON::PP -e '
    my $path = shift @ARGV;
    open my $fh, "<", $path or die "open $path: $!";
    my %out = (
      branch => "",
      worktree => "",
      pr => "",
      issue => "",
      validation_plan => [],
      validation_evidence => [],
    );
    my ($in_validation_plan, $in_results, $in_fence) = (0, 0, 0);
    while (my $line = <$fh>) {
      chomp $line;
      my $trim = $line;
      $trim =~ s/^\s+|\s+$//g;
      my $label = $trim;
      $label =~ s/^[-*]\s+//;
      $label =~ s/^\*\*([^*]+):\*\*/$1:/;

      if (!$out{branch} && $label =~ /^Branch:\s*(.+)$/i) {
        my $value = $1;
        $value = $1 if $value =~ /`([^`]+)`/;
        $value =~ s/\s+\(.*$//;
        $value =~ s/^\s+|\s+$//g;
        $out{branch} = $value;
      }
      if (!$out{worktree} && $label =~ /^Worktree:\s*(.+)$/i) {
        my $value = $1;
        $value = $1 if $value =~ /`([^`]+)`/;
        $value =~ s/^\s+|\s+$//g;
        $out{worktree} = $value;
      }
      if (!$out{pr} && $label =~ /^(?:PR|PR \/ issue):\s*(.+)$/i) {
        my $value = $1;
        $value = $1 if $value =~ /`([^`]+)`/;
        $value =~ s/^\s+|\s+$//g;
        $out{pr} = $value;
      }
      if (!$out{issue} && $label =~ /^Issue:\s*(.+)$/i) {
        my $value = $1;
        $value = $1 if $value =~ /`([^`]+)`/;
        $value =~ s/^\s+|\s+$//g;
        $out{issue} = $value;
      }

      if ($trim =~ /^##\s+Validation Plan\b/i) {
        $in_validation_plan = 1;
        $in_results = 0;
        $in_fence = 0;
        next;
      }
      if ($trim =~ /^##\s+(Validation Results|Current Validation|Current State|Status|Session Notes)\b/i) {
        $in_results = 1;
        $in_validation_plan = 0;
        $in_fence = 0;
        next;
      }
      if ($label =~ /^Current validation:\s*$/i) {
        $in_results = 1;
        $in_validation_plan = 0;
        $in_fence = 0;
        next;
      }
      if ($label =~ /^(Next action|Next Step|Validation to run|Guardrails|Decisions ratified|Work Context|Sessions):\s*$/i) {
        $in_validation_plan = 0;
        $in_results = 0;
        $in_fence = 0;
        next;
      }
      if ($trim =~ /^##\s+/) {
        $in_validation_plan = 0;
        $in_results = 0;
        $in_fence = 0;
      }

      if ($in_validation_plan && $trim =~ /^```/) {
        $in_fence = !$in_fence;
        next;
      }
      if ($in_validation_plan && $in_fence && length $trim && $trim !~ /^#/) {
        push @{$out{validation_plan}}, $trim;
      }

      if ($in_results && $trim =~ /^[-*]\s+(.+)/) {
        my $item = $1;
        if ($item =~ /(passed|green|returned|produced|completed|validation|validate|tests?|docker|compose|browser mcp|build|health checks|git diff|pnpm|vitest|node --check|config --quiet|zero console|0 broken)/i) {
          push @{$out{validation_evidence}}, $item if @{$out{validation_evidence}} < 12;
        }
      }
    }
    close $fh;

    for my $key (qw(branch worktree pr issue)) {
      $out{$key} =~ s/^\s+|\s+$//g;
    }
    my %seen;
    @{$out{validation_plan}} = grep { !$seen{$_}++ } @{$out{validation_plan}};
    %seen = ();
    @{$out{validation_evidence}} = grep { !$seen{$_}++ } @{$out{validation_evidence}};
    print JSON::PP->new->canonical->encode(\%out);
  ' "$source"
}

is_sensitive_path() {
  local path name
  path="$1"
  name="$(basename "$path" | lower_text)"
  case "$name" in
    *.env|*.pem|*.key|*secret*|*token*|*credential*|*password*) return 0 ;;
    *) return 1 ;;
  esac
}

emit_file_excerpt() {
  local label="$1" path="$2" max_bytes="$3" size
  [ -f "$path" ] || return 0
  echo
  echo "### $label"
  echo
  if is_sensitive_path "$path"; then
    echo "_Skipped sensitive-looking path._"
    return 0
  fi
  if ! LC_ALL=C grep -Iq . "$path"; then
    echo "_Skipped binary or non-text path._"
    return 0
  fi
  size="$(wc -c < "$path" | tr -d ' ')"
  echo '```text'
  if [ "$size" -gt "$max_bytes" ]; then
    head -c "$max_bytes" "$path"
    echo
    echo "[truncated after $max_bytes bytes]"
  else
    cat "$path"
  fi
  echo '```'
}

cmd_init() {
  need_jq
  local task_path="" kind="" repo="" request="" force=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      --kind) kind="${2:-}"; shift 2 ;;
      --repo) repo="${2:-}"; shift 2 ;;
      --request) request="${2:-}"; shift 2 ;;
      --force) force=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown init argument: $1" ;;
    esac
  done

  [ -n "$task_path" ] || die "init requires --task-path"
  mkdir -p "$task_path"
  [ -n "$request" ] || request="$(infer_request "$task_path")"
  [ -n "$repo" ] || repo="$(infer_repo "$task_path")"
  [ -n "$kind" ] || kind="$(infer_kind "$task_path" "$request")"
  valid_repo "$repo" || die "invalid repo: $repo"
  valid_kind "$kind" || die "invalid kind: $kind"

  local complexity risk_csv thinking_csv automation checkpoints_csv validation_csv updated workflow_file ledger_file tmp
  complexity="$(infer_complexity "$kind")"
  risk_csv="$(infer_risk_csv "$repo" "$kind" "$task_path")"
  thinking_csv="$(infer_thinking_csv "$kind")"
  automation="$(infer_automation "$kind")"
  checkpoints_csv="$(infer_checkpoints_csv "$repo" "$risk_csv")"
  validation_csv="$(infer_validation_plan_csv "$repo" "$kind")"
  updated="$(now_utc)"
  workflow_file="$(workflow_file_for "$task_path")"
  ledger_file="$(ledger_file_for "$task_path")"

  if [ -f "$workflow_file" ] && [ "$force" -ne 1 ]; then
    die "$workflow_file already exists; use --force to replace it"
  fi

  tmp="$(mktemp)"
  jq -n \
    --arg schema "$SCHEMA" \
    --arg updated "$updated" \
    --arg request "$request" \
    --arg repo "$repo" \
    --arg lifecycle_home "$task_path" \
    --arg kind "$kind" \
    --arg complexity "$complexity" \
    --arg risk_csv "$risk_csv" \
    --arg reason "Inferred by workflowctl init from task path and request; review before execution." \
    --arg thinking_csv "$thinking_csv" \
    --arg automation "$automation" \
    --arg checkpoints_csv "$checkpoints_csv" \
    --arg validation_csv "$validation_csv" \
    '
    def csv: split(",") | map(select(length > 0));
    {
      schema: $schema,
      updated: $updated,
      task: {
        request: $request,
        repo: $repo,
        lifecycle_home: $lifecycle_home,
        branch: "",
        worktree: "",
        pr: "",
        issue: ""
      },
      classification: {
        kind: $kind,
        complexity: $complexity,
        risk: ($risk_csv | csv),
        reason: $reason
      },
      mode: {
        thinking: ($thinking_csv | csv),
        automation: $automation,
        human_checkpoints: ($checkpoints_csv | csv)
      },
      preflight: {
        workspace_status_checked: false,
        active_rules_checked: false,
        task_resume_checked: false,
        worktree_checked: false,
        skills_selected: [],
        validation_plan: ($validation_csv | csv),
        blockers: []
      },
      surfaces: {
        mutable: [],
        sealed_evaluator: [],
        context_pack: ""
      },
      experiment: {
        budget: "",
        metric: "",
        keep_rule: "",
        complexity_delta: ""
      },
      packages: [
        {
          id: "P0",
          title: $request,
          write_scope: [],
          acceptance: [],
          status: "pending",
          validation: []
        }
      ],
      approvals: [
        { action: "push", required: true, granted: false, evidence: "" },
        { action: "pr", required: true, granted: false, evidence: "" },
        { action: "live-activation", required: true, granted: false, evidence: "" },
        { action: "destructive-cleanup", required: true, granted: false, evidence: "" },
        { action: "external-write", required: true, granted: false, evidence: "" },
        { action: "production-write", required: true, granted: false, evidence: "" }
      ],
      closeoff: {
        summary_updated: false,
        resume_updated: false,
        session_index_updated: false,
        durable_learning_route: "none",
        cleanup_decision: ""
      }
    }' > "$tmp"
  mv "$tmp" "$workflow_file"

  if [ ! -f "$ledger_file" ]; then
    printf '{"schema":"%s","type":"header","task_path":"%s","created":"%s"}\n' "$LEDGER_SCHEMA" "$task_path" "$updated" > "$ledger_file"
  fi

  echo "# Workflow Initialized"
  echo "- task_path: $task_path"
  echo "- workflow: $workflow_file"
  echo "- validation_ledger: $ledger_file"
  echo "- kind: $kind"
  echo "- repo: $repo"
  echo "- automation: $automation"
}

cmd_classify() {
  need_jq
  local task_path="" workflow_file repo kind request complexity risk_csv thinking_csv automation checkpoints_csv
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown classify argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "classify requires --task-path"
  workflow_file="$(workflow_file_for "$task_path")"

  if [ -f "$workflow_file" ]; then
    jq empty "$workflow_file" >/dev/null
    repo="$(read_workflow_field "$workflow_file" '.task.repo' "$(infer_repo "$task_path")")"
    request="$(read_workflow_field "$workflow_file" '.task.request' "$(infer_request "$task_path")")"
    kind="$(read_workflow_field "$workflow_file" '.classification.kind' "$(infer_kind "$task_path" "$request")")"
    complexity="$(read_workflow_field "$workflow_file" '.classification.complexity' "$(infer_complexity "$kind")")"
    risk_csv="$(jq -r '.classification.risk // [] | join(",")' "$workflow_file")"
    thinking_csv="$(jq -r '.mode.thinking // [] | join(",")' "$workflow_file")"
    automation="$(read_workflow_field "$workflow_file" '.mode.automation' "$(infer_automation "$kind")")"
    checkpoints_csv="$(jq -r '.mode.human_checkpoints // [] | join(",")' "$workflow_file")"
  else
    repo="$(infer_repo "$task_path")"
    request="$(infer_request "$task_path")"
    kind="$(infer_kind "$task_path" "$request")"
    complexity="$(infer_complexity "$kind")"
    risk_csv="$(infer_risk_csv "$repo" "$kind" "$task_path")"
    thinking_csv="$(infer_thinking_csv "$kind")"
    automation="$(infer_automation "$kind")"
    checkpoints_csv="$(infer_checkpoints_csv "$repo" "$risk_csv")"
  fi

  echo "# Workflow Classification"
  echo "- task_path: $task_path"
  echo "- workflow: $([ -f "$workflow_file" ] && echo present || echo missing)"
  echo "- request: $request"
  echo "- repo: $repo"
  echo "- kind: $kind"
  echo "- complexity: $complexity"
  echo "- risk: ${risk_csv:-none}"
  echo "- thinking: ${thinking_csv:-none}"
  echo "- automation: $automation"
  echo "- human_checkpoints: ${checkpoints_csv:-none}"
  if [ ! -f "$workflow_file" ]; then
    echo
    echo "Suggested next step: tools/workflowctl init --task-path \"$task_path\" --kind $kind --repo $repo"
  fi
}

cmd_hydrate() {
  need_jq
  local task_path="" source="" workflow_file extracted tmp repo branch worktree pr issue validation_count inferred_worktree
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      --source) source="$(normalize_path "${2:-}")"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown hydrate argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "hydrate requires --task-path"
  [ -d "$task_path" ] || die "task path does not exist: $task_path"
  [ -n "$source" ] || source="$task_path/resume.md"
  [ -f "$source" ] || die "hydrate source does not exist: $source"
  workflow_file="$(workflow_file_for "$task_path")"
  [ -f "$workflow_file" ] || die "workflow.json missing; run workflowctl init first"
  jq empty "$workflow_file" >/dev/null

  extracted="$(extract_resume_json "$source")"
  repo="$(read_workflow_field "$workflow_file" '.task.repo' "$(infer_repo "$task_path")")"
  branch="$(jq -r '.branch // ""' <<< "$extracted")"
  worktree="$(jq -r '.worktree // ""' <<< "$extracted")"
  pr="$(jq -r '.pr // ""' <<< "$extracted")"
  issue="$(jq -r '.issue // ""' <<< "$extracted")"
  validation_count="$(jq '.validation_plan | length' <<< "$extracted")"
  if [ -z "$worktree" ] && [ -n "$branch" ]; then
    inferred_worktree="$(infer_worktree_from_branch "$repo" "$branch" 2>/dev/null || true)"
    [ -n "$inferred_worktree" ] && worktree="$inferred_worktree"
  fi

  tmp="$(mktemp)"
  jq \
    --argjson extracted "$extracted" \
    --arg source "$source" \
    --arg updated "$(now_utc)" \
    --arg worktree "$worktree" \
    '
    .updated = $updated
    | .task.branch = (if ($extracted.branch // "") != "" then $extracted.branch else (.task.branch // "") end)
    | .task.worktree = (if $worktree != "" then $worktree else (.task.worktree // "") end)
    | .task.pr = (if ($extracted.pr // "") != "" then $extracted.pr else (.task.pr // "") end)
    | .task.issue = (if ($extracted.issue // "") != "" then $extracted.issue else (.task.issue // "") end)
    | .preflight.task_resume_checked = true
    | .preflight.worktree_checked = ((if $worktree != "" then true else (.preflight.worktree_checked // false) end))
    | .preflight.validation_plan = (if (($extracted.validation_plan // []) | length) > 0 then $extracted.validation_plan else (.preflight.validation_plan // []) end)
    | .preflight.hydrated_from = $source
    ' "$workflow_file" > "$tmp"
  mv "$tmp" "$workflow_file"

  echo "# Workflow Hydrated"
  echo "- task_path: $task_path"
  echo "- source: $source"
  echo "- branch: ${branch:-none}"
  echo "- worktree: ${worktree:-none}"
  echo "- pr: ${pr:-none}"
  echo "- issue: ${issue:-none}"
  echo "- validation_plan_entries: $validation_count"
}

cmd_status() {
