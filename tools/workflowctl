cmd_swarm_check() {
  need_jq
  local task_path="" workflow_file decision="" coordinator="" loop_cap="" agents_count=0 implementation_count=0 review_count=0 source_read_count=0
  local enabled="" invalid_lines="" missing_lines="" lane_contract_lines="" impl_missing_lines="" duplicate_mutable=""
  local blockers=() warnings=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown swarm check argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "swarm check requires --task-path"
  workflow_file="$(workflow_file_for "$task_path")"

  [ -d "$task_path" ] || blockers+=("task path does not exist")
  if [ ! -f "$workflow_file" ]; then
    blockers+=("workflow.json missing; run workflowctl init first")
  elif ! jq empty "$workflow_file" >/dev/null 2>&1; then
    blockers+=("workflow.json is invalid JSON")
  elif [ "$(jq 'has("swarm")' "$workflow_file")" != "true" ]; then
    blockers+=("swarm contract missing; run workflowctl swarm init first")
  else
    decision="$(read_workflow_field "$workflow_file" '.swarm.router_decision' "")"
    coordinator="$(read_workflow_field "$workflow_file" '.swarm.coordinator' "")"
    loop_cap="$(read_workflow_field "$workflow_file" '.swarm.loop_cap' "")"
    enabled="$(read_workflow_field "$workflow_file" '.swarm.enabled' "false")"
    agents_count="$(jq '.swarm.agents // [] | length' "$workflow_file")"
    implementation_count="$(jq '[.swarm.agents[]? | select(.role == "implementation")] | length' "$workflow_file")"
    review_count="$(jq '[.swarm.agents[]? | select(.role == "review" or .role == "validation")] | length' "$workflow_file")"
    source_read_count="$(jq '[.swarm.agents[]? | select(.role == "source-read")] | length' "$workflow_file")"

    [ -n "$decision" ] && valid_swarm_decision "$decision" || blockers+=("swarm.router_decision is missing or invalid")
    case "$decision:$enabled" in
      none:true) warnings+=("swarm.enabled=true while router_decision=none") ;;
      review-only:false|parallel-read:false|parallel-implement:false) warnings+=("swarm.enabled=false while router_decision=$decision") ;;
    esac

    if [ "$decision" = "none" ]; then
      [ "$agents_count" -eq 0 ] || warnings+=("swarm.router_decision=none but lane assignments exist")
    elif [ -n "$decision" ]; then
      [ -n "$coordinator" ] || blockers+=("swarm.coordinator is empty")
      [ -n "$loop_cap" ] || blockers+=("swarm.loop_cap is empty for non-none routing")
      [ "$agents_count" -gt 0 ] || blockers+=("swarm.agents is empty for non-none routing")

      case "$decision" in
        parallel-implement)
          [ "$implementation_count" -gt 0 ] || blockers+=("parallel-implement requires at least one implementation lane")
          ;;
        parallel-read)
          [ "$source_read_count" -gt 0 ] || blockers+=("parallel-read requires at least one source-read lane")
          ;;
        review-only)
          [ "$review_count" -gt 0 ] || blockers+=("review-only requires at least one review or validation lane")
          ;;
      esac

      missing_lines="$(jq -r '
        .swarm.agents[]?
        | select((.id // "") == "" or (.role // "") == "" or (.task // "") == "")
        | "\(.id // "missing-id"): missing id, role, or task"
      ' "$workflow_file")"
      while IFS= read -r line; do
        [ -n "$line" ] && blockers+=("$line")
      done <<< "$missing_lines"

      invalid_lines="$(jq -r '
        .swarm.agents[]?
        | select(((.role // "") as $r | ["source-read","implementation","validation","review"] | index($r) | not) or ((.status // "pending") as $s | ["pending","running","complete","blocked","discard"] | index($s) | not))
        | "\(.id // "missing-id"): invalid role or status"
      ' "$workflow_file")"
      while IFS= read -r line; do
        [ -n "$line" ] && blockers+=("$line")
      done <<< "$invalid_lines"

      lane_contract_lines="$(jq -r '
        .swarm.agents[]?
        | select(((.sealed_surface // []) | length) == 0 or (((.preflight // "") == "") and (((.stop_conditions // []) | length) == 0)))
        | "\(.id // "missing-id"): lane requires sealed surface and preflight or stop condition"
      ' "$workflow_file")"
      while IFS= read -r line; do
        [ -n "$line" ] && blockers+=("$line")
      done <<< "$lane_contract_lines"

      impl_missing_lines="$(jq -r '
        .swarm.agents[]?
        | select(.role == "implementation")
        | select(((.mutable_surface // []) | length) == 0 or ((.sealed_surface // []) | length) == 0 or ((.preflight // "") == ""))
        | "\(.id // "missing-id"): implementation lane requires mutable surface, sealed surface, and preflight"
      ' "$workflow_file")"
      while IFS= read -r line; do
        [ -n "$line" ] && blockers+=("$line")
      done <<< "$impl_missing_lines"

      if [ "$decision" = "parallel-implement" ]; then
        duplicate_mutable="$(jq -r '[.swarm.agents[]? | select(.role == "implementation") | .mutable_surface[]?] | group_by(.)[]? | select(length > 1) | .[0]' "$workflow_file" | paste -sd ',' -)"
        [ -z "$duplicate_mutable" ] || blockers+=("overlapping implementation mutable surfaces: $duplicate_mutable")
      fi
    fi
  fi

  echo "# Swarm Contract Check"
  echo "- task_path: $task_path"
  echo "- decision: ${decision:-missing}"
  echo "- agents: $agents_count"
  echo "- implementation_lanes: $implementation_count"
  echo "- source_read_lanes: $source_read_count"
  echo "- review_validation_lanes: $review_count"
  echo
  echo "## Warnings"
  if [ "${#warnings[@]}" -eq 0 ]; then
    echo "- none"
  else
    printf -- "- %s\n" "${warnings[@]}"
  fi
  echo
  echo "## Blockers"
  if [ "${#blockers[@]}" -eq 0 ]; then
    echo "- none"
    return 0
  fi
  printf -- "- %s\n" "${blockers[@]}"
  return 1
}

cmd_experiment_init() {
  need_jq
  local task_path="" mutable_csv="" sealed_csv="" budget="" metric="" keep_rule="" complexity_delta="" workflow_file experiment_file tmp
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      --mutable) mutable_csv="${2:-}"; shift 2 ;;
      --sealed-evaluator) sealed_csv="${2:-}"; shift 2 ;;
      --budget) budget="${2:-}"; shift 2 ;;
      --metric) metric="${2:-}"; shift 2 ;;
      --keep-rule) keep_rule="${2:-}"; shift 2 ;;
      --complexity-delta) complexity_delta="${2:-}"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown experiment init argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "experiment init requires --task-path"
  [ -d "$task_path" ] || die "task path does not exist: $task_path"
  [ -n "$mutable_csv" ] || die "experiment init requires --mutable"
  [ -n "$sealed_csv" ] || die "experiment init requires --sealed-evaluator"
  [ -n "$budget" ] || die "experiment init requires --budget"
  [ -n "$metric" ] || die "experiment init requires --metric"
  [ -n "$keep_rule" ] || die "experiment init requires --keep-rule"
  workflow_file="$(workflow_file_for "$task_path")"
  [ -f "$workflow_file" ] || die "workflow.json missing; run workflowctl init first"
  jq empty "$workflow_file" >/dev/null

  tmp="$(mktemp)"
  jq \
    --arg mutable_csv "$mutable_csv" \
    --arg sealed_csv "$sealed_csv" \
    --arg budget "$budget" \
    --arg metric "$metric" \
    --arg keep_rule "$keep_rule" \
    --arg complexity_delta "$complexity_delta" \
    '
    def csv: split(",") | map(gsub("^\\s+|\\s+$"; "")) | map(select(length > 0));
    .surfaces.mutable = ($mutable_csv | csv)
    | .surfaces.sealed_evaluator = ($sealed_csv | csv)
    | .experiment.budget = $budget
    | .experiment.metric = $metric
    | .experiment.keep_rule = $keep_rule
    | .experiment.complexity_delta = $complexity_delta
    ' "$workflow_file" > "$tmp"
  mv "$tmp" "$workflow_file"
  ensure_experiment_ledger "$task_path"
  experiment_file="$(experiment_file_for "$task_path")"

  echo "# Experiment Contract Initialized"
  echo "- task_path: $task_path"
  echo "- workflow: $workflow_file"
  echo "- experiment_ledger: $experiment_file"
}

cmd_experiment_check() {
  need_jq
  local task_path="" workflow_file mutable_count sealed_count budget metric keep_rule
  local blockers=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown experiment check argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "experiment check requires --task-path"
  workflow_file="$(workflow_file_for "$task_path")"
  if [ ! -f "$workflow_file" ]; then
    blockers+=("workflow.json missing")
  else
    jq empty "$workflow_file" >/dev/null
    mutable_count="$(jq '.surfaces.mutable // [] | length' "$workflow_file")"
    sealed_count="$(jq '.surfaces.sealed_evaluator // [] | length' "$workflow_file")"
    budget="$(read_workflow_field "$workflow_file" '.experiment.budget' "")"
    metric="$(read_workflow_field "$workflow_file" '.experiment.metric' "")"
    keep_rule="$(read_workflow_field "$workflow_file" '.experiment.keep_rule' "")"
    [ "$mutable_count" -gt 0 ] || blockers+=("surfaces.mutable is empty")
    [ "$sealed_count" -gt 0 ] || blockers+=("surfaces.sealed_evaluator is empty")
    [ -n "$budget" ] || blockers+=("experiment.budget is empty")
    [ -n "$metric" ] || blockers+=("experiment.metric is empty")
    [ -n "$keep_rule" ] || blockers+=("experiment.keep_rule is empty")
  fi

  echo "# Experiment Contract Check"
  echo "- task_path: $task_path"
  echo
  echo "## Blockers"
  if [ "${#blockers[@]}" -eq 0 ]; then
    echo "- none"
    return 0
  fi
  printf -- "- %s\n" "${blockers[@]}"
  return 1
}

cmd_experiment_record() {
  need_jq
  local task_path="" status="" candidate="" metric="" evidence="" complexity_delta="" notes="" experiment_file
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      --status) status="${2:-}"; shift 2 ;;
      --candidate) candidate="${2:-}"; shift 2 ;;
      --metric) metric="${2:-}"; shift 2 ;;
      --evidence) evidence="${2:-}"; shift 2 ;;
      --complexity-delta) complexity_delta="${2:-}"; shift 2 ;;
      --notes) notes="${2:-}"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown experiment record argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "experiment record requires --task-path"
  [ -d "$task_path" ] || die "task path does not exist: $task_path"
  [ -n "$status" ] || die "experiment record requires --status"
  valid_experiment_status "$status" || die "invalid experiment status: $status"
  cmd_experiment_check --task-path "$task_path" >/dev/null
  [ -n "$candidate" ] || candidate="candidate-$(date -u +%Y%m%dT%H%M%SZ)"
  ensure_experiment_ledger "$task_path"
  experiment_file="$(experiment_file_for "$task_path")"
  jq -c -n \
    --arg type "experiment" \
    --arg time "$(now_utc)" \
    --arg candidate "$candidate" \
    --arg status "$status" \
    --arg metric "$metric" \
    --arg evidence "$evidence" \
    --arg complexity_delta "$complexity_delta" \
    --arg notes "$notes" \
    '{type:$type,time:$time,candidate:$candidate,status:$status,metric:$metric,evidence:$evidence,complexity_delta:$complexity_delta,notes:$notes}' >> "$experiment_file"

  echo "# Experiment Recorded"
  echo "- task_path: $task_path"
  echo "- experiment_ledger: $experiment_file"
  echo "- candidate: $candidate"
  echo "- status: $status"
}

cmd_export() {
  need_jq
  local task_path="" format="" workflow_file
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      --format) format="${2:-}"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown export argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "export requires --task-path"
  [ -n "$format" ] || die "export requires --format"
  workflow_file="$(workflow_file_for "$task_path")"
  [ -f "$workflow_file" ] || die "workflow.json missing; run workflowctl init first"
  jq empty "$workflow_file" >/dev/null

  case "$format" in
    pi-workflow)
      jq --arg task_path "$task_path" '{
        schema: "workspace-control.export.pi-workflow.v0",
        task_path: $task_path,
        source_schema: .schema,
        request: .task.request,
        repo: .task.repo,
        classification: .classification,
        mode: .mode,
        implementation_gate: (.implementation_gate // {}),
        swarm: (.swarm // {}),
        validation_plan: (.preflight.validation_plan // []),
        approvals: [.approvals[]? | select(.required == true)],
        references: [
          "docs/specs/implementation-automation-kernel.md",
          "docs/reference/workflowctl.md"
        ]
      }' "$workflow_file"
      ;;
    agentic-runbook)
      echo "# Agentic Runbook Export"
      echo
      jq -r '
        "- request: \(.task.request // "missing")",
        "- repo: \(.task.repo // "missing")",
        "- kind: \(.classification.kind // "missing")",
        "- automation: \(.mode.automation // "missing")",
        "- thinking: \((.mode.thinking // []) | join(","))",
        "- gate: \(.implementation_gate.decision // "missing")",
        "- swarm: \(.swarm.router_decision // "missing")"
      ' "$workflow_file"
      echo
      echo "## Validation Plan"
      jq -r '(.preflight.validation_plan // [])[]? | "- " + .' "$workflow_file"
      echo
      echo "## Approval Stops"
      jq -r '.approvals[]? | select(.required == true) | "- " + .action' "$workflow_file"
      ;;
    swarm-runbook)
      echo "# Swarm Runbook Export"
      echo
      jq -r '
        "- request: \(.task.request // "missing")",
        "- repo: \(.task.repo // "missing")",
        "- worktree: \(.task.worktree // "missing")",
        "- gate_decision: \(.implementation_gate.decision // "missing")",
        "- scope_bucket: \(.implementation_gate.scope_bucket // "missing")",
        "- goal: \(.implementation_gate.goal // "missing")",
        "- brief: \(.implementation_gate.brief_path // "missing")",
        "- swarm_decision: \(.swarm.router_decision // "missing")",
        "- coordinator: \(.swarm.coordinator // "missing")",
        "- context_pack: \(.swarm.shared_context_pack // .surfaces.context_pack // "missing")",
        "- loop_cap: \(.swarm.loop_cap // "missing")"
      ' "$workflow_file"
      echo
      echo "## Source Read"
      jq -r '(.implementation_gate.source_read // []) | if length == 0 then "- none" else .[] | "- " + . end' "$workflow_file"
      echo
      echo "## Write Scope"
      jq -r '(.implementation_gate.write_scope // []) | if length == 0 then "- none" else .[] | "- " + . end' "$workflow_file"
      echo
      echo "## Validation Plan"
      jq -r '(((.implementation_gate.validation_plan // []) + (.preflight.validation_plan // [])) | unique) | if length == 0 then "- none" else .[] | "- " + . end' "$workflow_file"
      echo
      echo "## Lanes"
      jq -r '
        if ((.swarm.agents // []) | length) == 0 then
          "- none"
        else
          .swarm.agents[] |
          "- \(.id): \(.role) - \(.task)\n  mutable: \((.mutable_surface // []) | join(","))\n  sealed: \((.sealed_surface // []) | join(","))\n  worktree: \(.worktree // "")\n  preflight: \(.preflight // "")\n  handoff: \(.handoff_artifact // "")\n  status: \(.status // "pending")"
        end
      ' "$workflow_file"
      echo
      echo "## Forbidden Actions"
      jq -r '(.swarm.forbidden_actions // []) | if length == 0 then "- none" else .[] | "- " + . end' "$workflow_file"
      ;;
    *)
      die "unsupported export format: $format"
      ;;
  esac
}

cmd_metrics() {
  need_jq
  local root="$WORKSPACE_ROOT/detection-platform-metal-work" task workflow_file ledger_file route validation_entries
  local total=0 with_workflow=0 with_resume=0 with_summary=0 with_validation=0 with_validation_entries=0 with_passing_validation=0 with_learning_route=0 with_context_pack=0 with_experiment_contract=0 with_gate_promoted=0 with_swarm_decision=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --root) root="$(normalize_path "${2:-}")"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown metrics argument: $1" ;;
    esac
  done
  [ -d "$root" ] || die "metrics root does not exist: $root"

  while IFS= read -r -d '' task; do
    total=$((total + 1))
    workflow_file="$(workflow_file_for "$task")"
    ledger_file="$(ledger_file_for "$task")"
    [ -f "$task/resume.md" ] && with_resume=$((with_resume + 1))
    [ -f "$task/SUMMARY.md" ] && with_summary=$((with_summary + 1))
    if [ -f "$workflow_file" ] && jq empty "$workflow_file" >/dev/null 2>&1; then
      with_workflow=$((with_workflow + 1))
      route="$(read_workflow_field "$workflow_file" '.closeoff.durable_learning_route' "")"
      case "$route" in
        ""|none|*"|"*) ;;
        *) with_learning_route=$((with_learning_route + 1)) ;;
      esac
      if [ "$(read_workflow_field "$workflow_file" '.surfaces.context_pack' "")" != "" ]; then
        with_context_pack=$((with_context_pack + 1))
      fi
      if [ "$(jq '((.surfaces.mutable // []) | length) > 0 and ((.surfaces.sealed_evaluator // []) | length) > 0 and ((.experiment.budget // "") | length) > 0 and ((.experiment.metric // "") | length) > 0 and ((.experiment.keep_rule // "") | length) > 0' "$workflow_file")" = "true" ]; then
        with_experiment_contract=$((with_experiment_contract + 1))
      fi
      if [ "$(read_workflow_field "$workflow_file" '.implementation_gate.decision' "")" = "promote-to-implementation" ]; then
        with_gate_promoted=$((with_gate_promoted + 1))
      fi
      if [ "$(read_workflow_field "$workflow_file" '.swarm.router_decision' "")" != "" ]; then
        with_swarm_decision=$((with_swarm_decision + 1))
      fi
    fi
    if [ -f "$ledger_file" ] && jq -s empty "$ledger_file" >/dev/null 2>&1; then
      with_validation=$((with_validation + 1))
      validation_entries="$(jq -s '[.[] | select(.type == "validation")] | length' "$ledger_file")"
      [ "$validation_entries" -gt 0 ] && with_validation_entries=$((with_validation_entries + 1))
      if [ "$(jq -s '[.[] | select(.type == "validation" and .result == "pass")] | length' "$ledger_file")" -gt 0 ]; then
        with_passing_validation=$((with_passing_validation + 1))
      fi
    fi
  done < <(find "$root" -mindepth 2 -maxdepth 2 -type d \( -path "$root/busy/*" -o -path "$root/parked/*" -o -path "$root/done/*" -o -path "$root/archived/*" -o -path "$root/investigations/*" \) -print0 2>/dev/null)

  echo "# Workflow Metrics"
  echo "- root: $root"
  echo "- task_dirs: $total"
  echo "- with_workflow_json: $with_workflow"
  echo "- with_resume_md: $with_resume"
  echo "- with_summary_md: $with_summary"
  echo "- with_validation_jsonl: $with_validation"
  echo "- with_validation_entries: $with_validation_entries"
  echo "- with_passing_validation: $with_passing_validation"
  echo "- with_durable_learning_route: $with_learning_route"
  echo "- with_context_pack: $with_context_pack"
  echo "- with_experiment_contract: $with_experiment_contract"
  echo "- with_gate_promoted: $with_gate_promoted"
  echo "- with_swarm_decision: $with_swarm_decision"
}

cmd_close_check() {
  need_jq
  local task_path="" workflow_file ledger_file root route kind validation_entries passing_entries skipped_entries
  local blockers=() warnings=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown close-check argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "close-check requires --task-path"
  workflow_file="$(workflow_file_for "$task_path")"
  ledger_file="$(ledger_file_for "$task_path")"
  root="$(task_root_for_path "$task_path")"

  [ -d "$task_path" ] || blockers+=("task path does not exist")
  if [ ! -f "$workflow_file" ]; then
    blockers+=("workflow.json missing")
    kind=""
    route=""
  else
    jq empty "$workflow_file" >/dev/null
    kind="$(read_workflow_field "$workflow_file" '.classification.kind' "")"
    route="$(read_workflow_field "$workflow_file" '.closeoff.durable_learning_route' "")"
    case "$route" in
      ""|*"|"*) blockers+=("closeoff.durable_learning_route is missing or still a placeholder") ;;
    esac
    if [ "$(read_workflow_field "$workflow_file" '.closeoff.cleanup_decision' "")" = "" ]; then
      warnings+=("closeoff.cleanup_decision is empty")
    fi
  fi

  case "$task_path" in
    "$CONTROL_ROOT/docs"/*)
      warnings+=("docs-only workspace-control path; resume.md and SUMMARY.md may be intentionally absent")
      ;;
    *)
      [ -f "$task_path/resume.md" ] || blockers+=("resume.md missing")
      [ -f "$task_path/SUMMARY.md" ] || blockers+=("SUMMARY.md missing")
      ;;
  esac

  if [ -n "$root" ]; then
    [ -f "$root/SESSIONS.md" ] || blockers+=("SESSIONS.md missing at task root: $root")
  fi

  if [ ! -f "$ledger_file" ]; then
    blockers+=("validation.jsonl missing")
  else
    jq -s empty "$ledger_file" >/dev/null
    validation_entries="$(jq -s '[.[] | select(.type == "validation")] | length' "$ledger_file")"
    passing_entries="$(jq -s '[.[] | select(.type == "validation" and .result == "pass")] | length' "$ledger_file")"
    skipped_entries="$(jq -s '[.[] | select(.type == "validation" and .result == "skipped")] | length' "$ledger_file")"
    if [ "$validation_entries" -eq 0 ]; then
      case "$kind" in
        investigation|review) warnings+=("no validation entries recorded for $kind task") ;;
        *) blockers+=("no validation entries recorded") ;;
      esac
    elif [ "$passing_entries" -eq 0 ]; then
      case "$kind" in
        investigation|review) warnings+=("no passing validation entries recorded for $kind task") ;;
        *) blockers+=("no passing validation entries recorded") ;;
      esac
      [ "$skipped_entries" -eq 0 ] || warnings+=("skipped validation entries are historical or non-fresh evidence only")
    fi
  fi

  echo "# Workflow Close Check"
  echo "- task_path: $task_path"
  echo "- task_root: ${root:-none}"
  echo "- durable_learning_route: ${route:-missing}"
  echo
  echo "## Warnings"
  if [ "${#warnings[@]}" -eq 0 ]; then
    echo "- none"
  else
    printf -- "- %s\n" "${warnings[@]}"
  fi
  echo
  echo "## Blockers"
  if [ "${#blockers[@]}" -eq 0 ]; then
    echo "- none"
    return 0
  fi
  printf -- "- %s\n" "${blockers[@]}"
  return 1
}

cmd="${1:-}"
case "$cmd" in
  init) shift; cmd_init "$@" ;;
  classify) shift; cmd_classify "$@" ;;
  hydrate) shift; cmd_hydrate "$@" ;;
  preflight) shift; cmd_preflight "$@" ;;
  status) shift; cmd_status "$@" ;;
  validation)
    shift
    subcmd="${1:-}"
    case "$subcmd" in
      add) shift; cmd_validation_add "$@" ;;
      import) shift; cmd_validation_import "$@" ;;
      -h|--help|"") usage ;;
      *) usage >&2; exit 2 ;;
    esac
    ;;
  validate) shift; cmd_validate "$@" ;;
  context-pack) shift; cmd_context_pack "$@" ;;
  gate)
    shift
    subcmd="${1:-}"
    case "$subcmd" in
      init) shift; cmd_gate_init "$@" ;;
      record) shift; cmd_gate_record "$@" ;;
      check) shift; cmd_gate_check "$@" ;;
      -h|--help|"") usage ;;
      *) usage >&2; exit 2 ;;
    esac
    ;;
  swarm)
    shift
    subcmd="${1:-}"
    case "$subcmd" in
      init) shift; cmd_swarm_init "$@" ;;
      assign) shift; cmd_swarm_assign "$@" ;;
      record) shift; cmd_swarm_record "$@" ;;
      check) shift; cmd_swarm_check "$@" ;;
      -h|--help|"") usage ;;
      *) usage >&2; exit 2 ;;
    esac
    ;;
  experiment)
    shift
    subcmd="${1:-}"
    case "$subcmd" in
      init) shift; cmd_experiment_init "$@" ;;
      check) shift; cmd_experiment_check "$@" ;;
      record) shift; cmd_experiment_record "$@" ;;
      -h|--help|"") usage ;;
      *) usage >&2; exit 2 ;;
    esac
    ;;
  export) shift; cmd_export "$@" ;;
  metrics) shift; cmd_metrics "$@" ;;
  close-check) shift; cmd_close_check "$@" ;;
  -h|--help|"") usage ;;
  *) usage >&2; exit 2 ;;
esac
