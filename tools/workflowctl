  echo "- evidence_items: $evidence_count"
  echo "- result: skipped"
}

cmd_preflight() {
  need_jq
  local task_path="" workflow_file repo kind worktree validation_count root
  local blockers=() warnings=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown preflight argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "preflight requires --task-path"
  workflow_file="$(workflow_file_for "$task_path")"

  [ -d "$task_path" ] || blockers+=("task path does not exist")
  [ -f "$WORKSPACE_ROOT/AGENTS.md" ] || blockers+=("active workspace instructions missing at $WORKSPACE_ROOT/AGENTS.md")
  [ -f "$CONTROL_ROOT/docs/specs/implementation-automation-kernel.md" ] || blockers+=("kernel spec missing")
  if [ ! -f "$workflow_file" ]; then
    blockers+=("workflow.json missing; run workflowctl init first")
  else
    jq empty "$workflow_file" >/dev/null || blockers+=("workflow.json is invalid JSON")
    repo="$(read_workflow_field "$workflow_file" '.task.repo' "")"
    kind="$(read_workflow_field "$workflow_file" '.classification.kind' "")"
    worktree="$(read_workflow_field "$workflow_file" '.task.worktree' "")"
    validation_count="$(jq '.preflight.validation_plan // [] | length' "$workflow_file")"
    [ "$(read_workflow_field "$workflow_file" '.schema' "")" = "$SCHEMA" ] || blockers+=("workflow schema is not $SCHEMA")
    [ -n "$repo" ] && valid_repo "$repo" || blockers+=("task.repo is missing or invalid")
    [ -n "$kind" ] && valid_kind "$kind" || blockers+=("classification.kind is missing or invalid")
    [ "$validation_count" -gt 0 ] || blockers+=("preflight.validation_plan is empty")
    if [ -n "$worktree" ] && [ ! -d "$worktree" ]; then
      blockers+=("declared worktree does not exist: $worktree")
    fi
    case "$repo:$kind" in
      detection-platform-metal:implementation|detection-agentic-workflows:implementation)
        [ -n "$worktree" ] || blockers+=("implementation task is missing task.worktree")
        ;;
    esac
  fi

  [ -f "$task_path/resume.md" ] || warnings+=("resume.md missing")
  root="$(task_root_for_path "$task_path")"
  if [ -n "$root" ] && [ ! -f "$root/SESSIONS.md" ]; then
    warnings+=("task root has no SESSIONS.md: $root")
  fi

  echo "# Workflow Preflight"
  echo "- task_path: $task_path"
  echo "- active_rules: $([ -f "$WORKSPACE_ROOT/AGENTS.md" ] && echo present || echo missing)"
  echo "- kernel_spec: $([ -f "$CONTROL_ROOT/docs/specs/implementation-automation-kernel.md" ] && echo present || echo missing)"
  echo
  echo "## Warnings"
  if [ "${#warnings[@]}" -eq 0 ]; then
    echo "- none"
  else
    printf -- "- %s\n" "${warnings[@]}"
  fi
  echo
  echo "## Blockers"
  if [ "${#blockers[@]}" -eq 0 ]; then
    echo "- none"
    return 0
  fi
  printf -- "- %s\n" "${blockers[@]}"
  return 1
}

cmd_validate() {
  need_jq
  local task_path="" ledger_file entries failures blocked passes historical skipped
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown validate argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "validate requires --task-path"
  ledger_file="$(ledger_file_for "$task_path")"

  echo "# Validation Ledger"
  echo "- task_path: $task_path"
  echo "- validation_ledger: $ledger_file"
  if [ ! -f "$ledger_file" ]; then
    echo
    echo "## Blockers"
    echo "- validation.jsonl missing"
    return 1
  fi
  jq -s empty "$ledger_file" >/dev/null
  entries="$(jq -s '[.[] | select(.type == "validation")] | length' "$ledger_file")"
  passes="$(jq -s '[.[] | select(.type == "validation" and .result == "pass")] | length' "$ledger_file")"
  failures="$(jq -s '[.[] | select(.type == "validation" and .result == "fail")] | length' "$ledger_file")"
  blocked="$(jq -s '[.[] | select(.type == "validation" and .result == "blocked")] | length' "$ledger_file")"
  skipped="$(jq -s '[.[] | select(.type == "validation" and .result == "skipped")] | length' "$ledger_file")"
  historical="$(jq -s '[.[] | select(.type == "validation" and .historical == true)] | length' "$ledger_file")"
  echo "- validation_entries: $entries"
  echo "- passing_entries: $passes"
  echo "- historical_entries: $historical"
  echo
  echo "## Results"
  jq -r -s '
    [.[] | select(.type == "validation")]
    | if length == 0 then "- none"
      else group_by(.result // "missing")
        | map("- " + (.[0].result // "missing") + ": " + (length|tostring))
        | .[]
      end
  ' "$ledger_file"
  if [ "$entries" -eq 0 ] || [ "$passes" -eq 0 ] || [ "$failures" -gt 0 ] || [ "$blocked" -gt 0 ]; then
    echo
    echo "## Blockers"
    [ "$entries" -gt 0 ] || echo "- no validation entries recorded"
    [ "$passes" -gt 0 ] || echo "- no passing validation entries recorded"
    [ "$failures" -eq 0 ] || echo "- failing validation entries recorded"
    [ "$blocked" -eq 0 ] || echo "- blocked validation entries recorded"
    [ "$skipped" -eq 0 ] || echo "- skipped entries do not count as fresh validation passes"
    return 1
  fi
}

cmd_context_pack() {
  need_jq
  local task_path="" output="" max_bytes=12000 workflow_file ledger_file experiment_file worktree tmp
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      --output) output="${2:-}"; shift 2 ;;
      --max-bytes) max_bytes="${2:-}"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown context-pack argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "context-pack requires --task-path"
  [ -d "$task_path" ] || die "task path does not exist: $task_path"
  case "$max_bytes" in
    ''|*[!0-9]*) die "--max-bytes must be a positive integer" ;;
  esac
  [ "$max_bytes" -gt 0 ] || die "--max-bytes must be greater than zero"

  if [ -z "$output" ]; then
    mkdir -p "$task_path/artifacts"
    output="$task_path/artifacts/context-pack-$(date -u +%Y%m%dT%H%M%SZ).md"
  elif [ "$output" != "-" ]; then
    output="$(normalize_path "$output")"
    case "$output" in
      "$task_path"/*) mkdir -p "$(dirname "$output")" ;;
      *) die "--output must be under --task-path or '-' for stdout" ;;
    esac
  fi

  workflow_file="$(workflow_file_for "$task_path")"
  ledger_file="$(ledger_file_for "$task_path")"
  experiment_file="$(experiment_file_for "$task_path")"
  if [ "$output" != "-" ] && [ -f "$workflow_file" ]; then
    tmp="$(mktemp)"
    jq --arg output "$output" '
      .surfaces.context_pack = $output
      | .stage_artifacts = ((.stage_artifacts // {}) + {
          context_pack: $output,
          worker_briefs: (.stage_artifacts.worker_briefs // []),
          worker_handoffs: (.stage_artifacts.worker_handoffs // []),
          reviews: (.stage_artifacts.reviews // []),
          polish: (.stage_artifacts.polish // []),
          ship: (.stage_artifacts.ship // "")
        })
      | .swarm.shared_context_pack = (if (.swarm.shared_context_pack // "") == "" then $output else .swarm.shared_context_pack end)
    ' "$workflow_file" > "$tmp"
    mv "$tmp" "$workflow_file"
  fi
  tmp="$(mktemp)"
  {
    echo "# Workflow Context Pack"
    echo
    echo "- generated: $(now_utc)"
    echo "- task_path: $task_path"
    echo "- workflow: $([ -f "$workflow_file" ] && echo present || echo missing)"
    echo "- validation_ledger: $([ -f "$ledger_file" ] && echo present || echo missing)"
    echo "- experiment_ledger: $([ -f "$experiment_file" ] && echo present || echo missing)"
    if [ -f "$workflow_file" ]; then
      jq empty "$workflow_file" >/dev/null
      echo
      echo "## Workflow Summary"
      echo
      jq -r '
        "- request: \(.task.request // "missing")",
        "- repo: \(.task.repo // "missing")",
        "- kind: \(.classification.kind // "missing")",
        "- complexity: \(.classification.complexity // "missing")",
        "- automation: \(.mode.automation // "missing")",
        "- risk: \((.classification.risk // []) | join(","))",
        "- thinking: \((.mode.thinking // []) | join(","))",
        "- checkpoints: \((.mode.human_checkpoints // []) | join(","))"
      ' "$workflow_file"
      worktree="$(read_workflow_field "$workflow_file" '.task.worktree' "")"
      if [ -n "$worktree" ] && [ -d "$worktree" ]; then
        echo
        echo "## Worktree"
        echo
        echo "- path: $worktree"
        if git -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
          echo
          echo '```text'
          git -C "$worktree" status --short
          git -C "$worktree" diff --stat
          echo '```'
        else
          echo "- not a git worktree"
        fi
      fi
    fi

    echo
    echo "## Task Files"
    emit_file_excerpt "resume.md" "$task_path/resume.md" "$max_bytes"
    emit_file_excerpt "SUMMARY.md" "$task_path/SUMMARY.md" "$max_bytes"
    emit_file_excerpt "notes.md" "$task_path/notes.md" "$max_bytes"
    emit_file_excerpt "LINEAGE.md" "$task_path/LINEAGE.md" "$max_bytes"
    emit_file_excerpt "workflow.json" "$workflow_file" "$max_bytes"
    emit_file_excerpt "validation.jsonl" "$ledger_file" "$max_bytes"
    emit_file_excerpt "experiment.jsonl" "$experiment_file" "$max_bytes"
  } > "$tmp"

  if [ "$output" = "-" ]; then
    cat "$tmp"
    rm -f "$tmp"
  else
    mv "$tmp" "$output"
    echo "# Context Pack Written"
    echo "- task_path: $task_path"
    echo "- output: $output"
  fi
}

cmd_gate_init() {
  need_jq
  local task_path="" scope_bucket="" decision="" workflow_file tmp
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      --scope-bucket) scope_bucket="${2:-}"; shift 2 ;;
      --decision) decision="${2:-}"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown gate init argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "gate init requires --task-path"
  [ -z "$scope_bucket" ] || valid_scope_bucket "$scope_bucket" || die "invalid scope bucket: $scope_bucket"
  [ -z "$decision" ] || valid_gate_decision "$decision" || die "invalid gate decision: $decision"

  workflow_file="$(workflow_file_for "$task_path")"
  if [ ! -f "$workflow_file" ]; then
    cmd_init --task-path "$task_path" >/dev/null
  fi
  jq empty "$workflow_file" >/dev/null

  tmp="$(mktemp)"
  jq \
    --arg updated "$(now_utc)" \
    --arg task_path "$task_path" \
    --arg scope_bucket "$scope_bucket" \
    --arg decision "$decision" \
    '
    def gate_defaults: {
      decision: "continue-exploration",
      scope_bucket: "",
      exploration_sources: [],
      source_read: [],
      problem_statement: "",
      goal: "",
      non_goals: [],
      implementation_home: $task_path,
      brief_path: "",
      prd_path: "",
      write_scope: [],
      sealed_surfaces: [],
      validation_plan: [],
      open_questions: [],
      approval_stops: (.mode.human_checkpoints // []),
      approved_by: "",
      approval_evidence: ""
    };
    .updated = $updated
    | .implementation_gate = (gate_defaults + (.implementation_gate // {}))
    | .implementation_gate.implementation_home = ((.implementation_gate.implementation_home // "") as $home | if $home == "" then $task_path else $home end)
    | .implementation_gate.approval_stops = (if ((.implementation_gate.approval_stops // []) | length) == 0 then (.mode.human_checkpoints // []) else .implementation_gate.approval_stops end)
    | .stage_artifacts = ((.stage_artifacts // {}) + {
        brief: (.stage_artifacts.brief // ""),
        context_pack: (.stage_artifacts.context_pack // .surfaces.context_pack // ""),
        worker_briefs: (.stage_artifacts.worker_briefs // []),
        worker_handoffs: (.stage_artifacts.worker_handoffs // []),
        reviews: (.stage_artifacts.reviews // []),
        polish: (.stage_artifacts.polish // []),
        ship: (.stage_artifacts.ship // "")
      })
    | (if $scope_bucket != "" then .implementation_gate.scope_bucket = $scope_bucket else . end)
    | (if $decision != "" then .implementation_gate.decision = $decision else . end)
    ' "$workflow_file" > "$tmp"
  mv "$tmp" "$workflow_file"

  echo "# Implementation Gate Initialized"
  echo "- task_path: $task_path"
  echo "- workflow: $workflow_file"
  echo "- decision: $(read_workflow_field "$workflow_file" '.implementation_gate.decision' "")"
  echo "- scope_bucket: $(read_workflow_field "$workflow_file" '.implementation_gate.scope_bucket' "unset")"
}

cmd_gate_record() {
  need_jq
  local task_path="" decision="" scope_bucket="" brief_path="" prd_path="" goal="" problem="" implementation_home=""
  local source_read_csv="" exploration_source_csv="" write_scope_csv="" sealed_surface_csv="" validation_csv=""
  local non_goal_csv="" open_question_csv="" approval_stop_csv="" approved_by="" approval_evidence=""
  local workflow_file tmp
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      --decision) decision="${2:-}"; shift 2 ;;
      --scope-bucket) scope_bucket="${2:-}"; shift 2 ;;
      --brief) brief_path="$(normalize_path "${2:-}")"; shift 2 ;;
      --prd) prd_path="$(normalize_path "${2:-}")"; shift 2 ;;
      --goal) goal="${2:-}"; shift 2 ;;
      --problem) problem="${2:-}"; shift 2 ;;
      --implementation-home) implementation_home="$(normalize_path "${2:-}")"; shift 2 ;;
      --source-read) source_read_csv="${2:-}"; shift 2 ;;
      --exploration-source) exploration_source_csv="${2:-}"; shift 2 ;;
      --write-scope) write_scope_csv="${2:-}"; shift 2 ;;
      --sealed-surface) sealed_surface_csv="${2:-}"; shift 2 ;;
      --validation) validation_csv="${2:-}"; shift 2 ;;
      --non-goal) non_goal_csv="${2:-}"; shift 2 ;;
      --open-question) open_question_csv="${2:-}"; shift 2 ;;
      --approval-stop) approval_stop_csv="${2:-}"; shift 2 ;;
      --approved-by) approved_by="${2:-}"; shift 2 ;;
      --approval-evidence) approval_evidence="${2:-}"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown gate record argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "gate record requires --task-path"
  [ -n "$decision" ] || die "gate record requires --decision"
  valid_gate_decision "$decision" || die "invalid gate decision: $decision"
  [ -z "$scope_bucket" ] || valid_scope_bucket "$scope_bucket" || die "invalid scope bucket: $scope_bucket"

  workflow_file="$(workflow_file_for "$task_path")"
  if [ ! -f "$workflow_file" ]; then
    cmd_gate_init --task-path "$task_path" >/dev/null
  fi
  jq empty "$workflow_file" >/dev/null

  tmp="$(mktemp)"
  jq \
    --arg updated "$(now_utc)" \
    --arg task_path "$task_path" \
    --arg decision "$decision" \
    --arg scope_bucket "$scope_bucket" \
    --arg brief_path "$brief_path" \
    --arg prd_path "$prd_path" \
    --arg goal "$goal" \
    --arg problem "$problem" \
    --arg implementation_home "$implementation_home" \
    --arg source_read_csv "$source_read_csv" \
    --arg exploration_source_csv "$exploration_source_csv" \
    --arg write_scope_csv "$write_scope_csv" \
    --arg sealed_surface_csv "$sealed_surface_csv" \
    --arg validation_csv "$validation_csv" \
    --arg non_goal_csv "$non_goal_csv" \
    --arg open_question_csv "$open_question_csv" \
    --arg approval_stop_csv "$approval_stop_csv" \
    --arg approved_by "$approved_by" \
    --arg approval_evidence "$approval_evidence" \
    '
    def csv($s): $s | split(",") | map(gsub("^\\s+|\\s+$"; "")) | map(select(length > 0));
    def merge_csv($old; $s): if $s == "" then ($old // []) else ((($old // []) + csv($s)) | unique) end;
    def gate_defaults: {
      decision: "continue-exploration",
      scope_bucket: "",
      exploration_sources: [],
      source_read: [],
      problem_statement: "",
      goal: "",
      non_goals: [],
      implementation_home: $task_path,
      brief_path: "",
      prd_path: "",
      write_scope: [],
      sealed_surfaces: [],
      validation_plan: [],
      open_questions: [],
      approval_stops: (.mode.human_checkpoints // []),
      approved_by: "",
      approval_evidence: ""
    };
    .updated = $updated
    | .implementation_gate = (gate_defaults + (.implementation_gate // {}))
    | .stage_artifacts = ((.stage_artifacts // {}) + {
        brief: (.stage_artifacts.brief // ""),
        context_pack: (.stage_artifacts.context_pack // .surfaces.context_pack // ""),
        worker_briefs: (.stage_artifacts.worker_briefs // []),
        worker_handoffs: (.stage_artifacts.worker_handoffs // []),
        reviews: (.stage_artifacts.reviews // []),
        polish: (.stage_artifacts.polish // []),
        ship: (.stage_artifacts.ship // "")
      })
    | .implementation_gate.decision = $decision
    | (if $scope_bucket != "" then .implementation_gate.scope_bucket = $scope_bucket else . end)
    | (if $brief_path != "" then .implementation_gate.brief_path = $brief_path | .stage_artifacts.brief = $brief_path else . end)
    | (if $prd_path != "" then .implementation_gate.prd_path = $prd_path else . end)
    | (if $goal != "" then .implementation_gate.goal = $goal else . end)
    | (if $problem != "" then .implementation_gate.problem_statement = $problem else . end)
    | (if $implementation_home != "" then .implementation_gate.implementation_home = $implementation_home else . end)
    | .implementation_gate.source_read = merge_csv(.implementation_gate.source_read; $source_read_csv)
    | .implementation_gate.exploration_sources = merge_csv(.implementation_gate.exploration_sources; $exploration_source_csv)
    | .implementation_gate.write_scope = merge_csv(.implementation_gate.write_scope; $write_scope_csv)
    | .implementation_gate.sealed_surfaces = merge_csv(.implementation_gate.sealed_surfaces; $sealed_surface_csv)
    | .implementation_gate.validation_plan = merge_csv(.implementation_gate.validation_plan; $validation_csv)
    | .implementation_gate.non_goals = merge_csv(.implementation_gate.non_goals; $non_goal_csv)
    | .implementation_gate.open_questions = merge_csv(.implementation_gate.open_questions; $open_question_csv)
    | .implementation_gate.approval_stops = (if $approval_stop_csv != "" then merge_csv(.implementation_gate.approval_stops; $approval_stop_csv) elif ((.implementation_gate.approval_stops // []) | length) == 0 then (.mode.human_checkpoints // []) else .implementation_gate.approval_stops end)
    | (if $approved_by != "" then .implementation_gate.approved_by = $approved_by else . end)
    | (if $approval_evidence != "" then .implementation_gate.approval_evidence = $approval_evidence else . end)
    ' "$workflow_file" > "$tmp"
  mv "$tmp" "$workflow_file"

  echo "# Implementation Gate Recorded"
  echo "- task_path: $task_path"
  echo "- decision: $decision"
  echo "- scope_bucket: $(read_workflow_field "$workflow_file" '.implementation_gate.scope_bucket' "unset")"
  echo "- brief: $(read_workflow_field "$workflow_file" '.implementation_gate.brief_path' "unset")"
}

cmd_gate_check() {
  need_jq
  local task_path="" workflow_file decision="" scope_bucket="" brief_path="" brief_resolved="" swarm_decision=""
  local source_count=0 write_count=0 validation_count=0 approval_count=0
  local blockers=() warnings=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown gate check argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "gate check requires --task-path"
  workflow_file="$(workflow_file_for "$task_path")"

  [ -d "$task_path" ] || blockers+=("task path does not exist")
  if [ ! -f "$workflow_file" ]; then
    blockers+=("workflow.json missing; run workflowctl init first")
  elif ! jq empty "$workflow_file" >/dev/null 2>&1; then
    blockers+=("workflow.json is invalid JSON")
  elif [ "$(jq 'has("implementation_gate")' "$workflow_file")" != "true" ]; then
    blockers+=("implementation_gate missing; run workflowctl gate init first")
  else
    decision="$(read_workflow_field "$workflow_file" '.implementation_gate.decision' "")"
    scope_bucket="$(read_workflow_field "$workflow_file" '.implementation_gate.scope_bucket' "")"
    brief_path="$(read_workflow_field "$workflow_file" '.implementation_gate.brief_path' "")"
    swarm_decision="$(read_workflow_field "$workflow_file" '.swarm.router_decision' "")"
    source_count="$(jq '.implementation_gate.source_read // [] | length' "$workflow_file")"
    write_count="$(jq '.implementation_gate.write_scope // [] | length' "$workflow_file")"
    validation_count="$(jq '(((.implementation_gate.validation_plan // []) + (.preflight.validation_plan // [])) | unique | length)' "$workflow_file")"
    approval_count="$(jq '.implementation_gate.approval_stops // [] | length' "$workflow_file")"

    [ -n "$decision" ] && valid_gate_decision "$decision" || blockers+=("implementation_gate.decision is missing or invalid")
    [ -z "$scope_bucket" ] || valid_scope_bucket "$scope_bucket" || blockers+=("implementation_gate.scope_bucket is invalid: $scope_bucket")
    [ -z "$swarm_decision" ] || valid_swarm_decision "$swarm_decision" || blockers+=("swarm.router_decision is invalid: $swarm_decision")

    case "$decision" in
      continue-exploration)
        blockers+=("gate decision is continue-exploration; implementation is not cleared")
        ;;
      stop)
        blockers+=("gate decision is stop")
        ;;
      promote-to-implementation)
        [ -n "$scope_bucket" ] || blockers+=("implementation_gate.scope_bucket is empty")
        [ "$(read_workflow_field "$workflow_file" '.implementation_gate.goal' "")" != "" ] || blockers+=("implementation_gate.goal is empty")
        [ "$source_count" -gt 0 ] || blockers+=("implementation_gate.source_read is empty")
        [ "$write_count" -gt 0 ] || blockers+=("implementation_gate.write_scope is empty")
        [ "$validation_count" -gt 0 ] || blockers+=("implementation validation plan is empty")
        [ "$approval_count" -gt 0 ] || blockers+=("implementation_gate.approval_stops is empty")
        [ -n "$brief_path" ] || blockers+=("implementation_gate.brief_path is empty")
        if [ -n "$brief_path" ]; then
          case "$brief_path" in
            /*) brief_resolved="$brief_path" ;;
            *) brief_resolved="$task_path/$brief_path" ;;
          esac
          [ -f "$brief_resolved" ] || blockers+=("implementation brief does not exist: $brief_path")
        fi
        ;;
    esac

    case "$scope_bucket:$swarm_decision" in
      trivial:parallel-implement)
        warnings+=("trivial scope bucket rarely needs parallel-implement swarm routing")
        ;;
      standard:none|wide:none)
        warnings+=("$scope_bucket scope bucket has swarm.router_decision=none; confirm the implementation is still coordinator-only")
        ;;
      standard:|wide:)
        warnings+=("$scope_bucket scope bucket has no swarm routing decision recorded")
        ;;
    esac
  fi

  echo "# Implementation Gate Check"
  echo "- task_path: $task_path"
  echo "- decision: ${decision:-missing}"
  echo "- scope_bucket: ${scope_bucket:-missing}"
  echo "- source_read_entries: $source_count"
  echo "- write_scope_entries: $write_count"
  echo "- validation_entries: $validation_count"
  echo
  echo "## Warnings"
  if [ "${#warnings[@]}" -eq 0 ]; then
    echo "- none"
  else
    printf -- "- %s\n" "${warnings[@]}"
  fi
  echo
  echo "## Blockers"
  if [ "${#blockers[@]}" -eq 0 ]; then
    echo "- none"
    return 0
  fi
  printf -- "- %s\n" "${blockers[@]}"
  return 1
}

cmd_swarm_init() {
  need_jq
  local task_path="" decision="" coordinator="" loop_cap="" workflow_file tmp
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --task-path) task_path="$(normalize_path "${2:-}")"; shift 2 ;;
      --decision) decision="${2:-}"; shift 2 ;;
      --coordinator) coordinator="${2:-}"; shift 2 ;;
      --loop-cap) loop_cap="${2:-}"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown swarm init argument: $1" ;;
    esac
  done
  [ -n "$task_path" ] || die "swarm init requires --task-path"
  [ -n "$decision" ] || die "swarm init requires --decision"
  valid_swarm_decision "$decision" || die "invalid swarm decision: $decision"

  workflow_file="$(workflow_file_for "$task_path")"
  if [ ! -f "$workflow_file" ]; then
    cmd_init --task-path "$task_path" >/dev/null
  fi
  jq empty "$workflow_file" >/dev/null

  tmp="$(mktemp)"
  jq \
    --arg updated "$(now_utc)" \
    --arg decision "$decision" \
    --arg coordinator "$coordinator" \
    --arg loop_cap "$loop_cap" \
    '
    def swarm_defaults: {
      enabled: false,
      router_decision: "",
      coordinator: "primary-agent",
      shared_context_pack: "",
      merge_policy: "coordinator-applies",
      conflict_policy: "stop-and-report",
      loop_cap: "",
      agents: [],
      forbidden_actions: [
        "push",
        "pr",
        "merge",
        "live-activation",
        "production-write",
        "external-write",
        "destructive-cleanup"
      ]
    };
    .updated = $updated
    | .swarm = (swarm_defaults + (.swarm // {}))
    | .swarm.router_decision = $decision
    | .swarm.enabled = ($decision != "none")
    | (if $coordinator != "" then .swarm.coordinator = $coordinator else . end)
    | (if $loop_cap != "" then .swarm.loop_cap = $loop_cap else . end)
    | .swarm.shared_context_pack = (if (.swarm.shared_context_pack // "") == "" then (.surfaces.context_pack // .stage_artifacts.context_pack // "") else .swarm.shared_context_pack end)
    ' "$workflow_file" > "$tmp"
  mv "$tmp" "$workflow_file"

  echo "# Swarm Contract Initialized"
  echo "- task_path: $task_path"
  echo "- decision: $decision"
  echo "- enabled: $([ "$decision" = "none" ] && echo false || echo true)"
}

