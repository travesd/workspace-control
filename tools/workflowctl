    esac
  done
  [ -n "$task_path" ] || die "status requires --task-path"
  workflow_file="$(workflow_file_for "$task_path")"
  ledger_file="$(ledger_file_for "$task_path")"

  echo "# Workflow Status"
  echo "- task_path: $task_path"
  echo "- task_dir: $([ -d "$task_path" ] && echo present || echo missing)"
  echo "- workflow: $([ -f "$workflow_file" ] && echo present || echo missing)"
  echo "- resume: $([ -f "$task_path/resume.md" ] && echo present || echo missing)"
  echo "- summary: $([ -f "$task_path/SUMMARY.md" ] && echo present || echo missing)"
  echo "- validation_ledger: $([ -f "$ledger_file" ] && echo present || echo missing)"

  if [ -f "$workflow_file" ]; then
    jq empty "$workflow_file" >/dev/null
    echo
    echo "## Classification"
    jq -r '
      "- repo: \(.task.repo // "missing")",
      "- kind: \(.classification.kind // "missing")",
      "- complexity: \(.classification.complexity // "missing")",
      "- automation: \(.mode.automation // "missing")",
      "- risk: \((.classification.risk // []) | join(","))"
    ' "$workflow_file"
    echo
    echo "## Packages"
    jq -r '.packages[]? | "- \(.id): \(.status) - \(.title)"' "$workflow_file"
    echo
    echo "## Approval Stops"
    local approvals
    approvals="$(jq -r '.approvals[]? | select(.required == true and .granted != true) | "- \(.action)"' "$workflow_file")"
    if [ -n "$approvals" ]; then
      printf '%s\n' "$approvals"
    else
      echo "- none"
    fi
    echo
    echo "## Closeoff"
    jq -r '
      "- summary_updated: \(.closeoff.summary_updated // false)",
      "- resume_updated: \(.closeoff.resume_updated // false)",
      "- session_index_updated: \(.closeoff.session_index_updated // false)",
      "- durable_learning_route: \(.closeoff.durable_learning_route // "missing")"
    ' "$workflow_file"
  fi
}

