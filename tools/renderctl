#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if ROOT="$(git -C "$SCRIPT_DIR/.." rev-parse --show-toplevel 2>/dev/null)"; then
  :
else
  ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
fi

usage() {
  cat <<'USAGE'
usage:
  tools/renderctl dry-run [--mode all|compatibility|instructions] [--out <dir>] [--keep]

Render the current workspace-control compatibility outputs into a generated
tree and diff them against the checked-in live-compatible sources.

This is intentionally conservative. The default mode checks both the current
compatibility copy and the draft instruction composition. It never writes to the
live workspace.
USAGE
}

rel_files() {
  local rel="$1"
  find "$ROOT/$rel" -type f \
    ! -path '*/.DS_Store' \
    -printf '%P\n' | sort
}

copy_tree() {
  local source_rel="$1"
  local target_rel="$2"
  local generated_root="$3"

  if [ ! -d "$ROOT/$source_rel" ]; then
    echo "missing source directory: $source_rel" >&2
    return 1
  fi

  mkdir -p "$generated_root/$(dirname "$target_rel")"
  rm -rf "$generated_root/$target_rel"
  mkdir -p "$generated_root/$target_rel"
  cp -a "$ROOT/$source_rel/." "$generated_root/$target_rel/"
}

compare_tree() {
  local target_rel="$1"
  local generated_root="$2"
  local diff_dir="$3"
  local diff_file="$diff_dir/${target_rel//\//__}.diff"
  local meta_current="$diff_dir/${target_rel//\//__}.current-metadata"
  local meta_generated="$diff_dir/${target_rel//\//__}.generated-metadata"
  local status=0

  if diff -ruN "$ROOT/$target_rel" "$generated_root/$target_rel" >"$diff_file"; then
    rm -f "$diff_file"
    printf -- "- %s content: clean\n" "$target_rel"
  else
    printf -- "- %s content: differs (diff: %s)\n" "$target_rel" "$diff_file"
    sed -n '1,200p' "$diff_file"
    status=1
  fi

  (
    cd "$ROOT/$target_rel"
    find . -type f -printf '%m\t%P\n' | sort
  ) >"$meta_current"
  (
    cd "$generated_root/$target_rel"
    find . -type f -printf '%m\t%P\n' | sort
  ) >"$meta_generated"

  if diff -u "$meta_current" "$meta_generated" >"$diff_file.metadata"; then
    rm -f "$meta_current" "$meta_generated" "$diff_file.metadata"
    printf -- "- %s metadata: clean\n" "$target_rel"
  else
    printf -- "- %s metadata: differs (diff: %s)\n" "$target_rel" "$diff_file.metadata"
    sed -n '1,200p' "$diff_file.metadata"
    status=1
  fi

  return "$status"
}

compare_file() {
  local target_rel="$1"
  local generated_root="$2"
  local diff_dir="$3"
  local diff_file="$diff_dir/${target_rel//\//__}.diff"
  local meta_current="$diff_dir/${target_rel//\//__}.current-metadata"
  local meta_generated="$diff_dir/${target_rel//\//__}.generated-metadata"
  local status=0

  if diff -u "$ROOT/$target_rel" "$generated_root/$target_rel" >"$diff_file"; then
    rm -f "$diff_file"
    printf -- "- %s content: clean\n" "$target_rel"
  else
    printf -- "- %s content: differs (diff: %s)\n" "$target_rel" "$diff_file"
    sed -n '1,200p' "$diff_file"
    status=1
  fi

  stat -c '%a' "$ROOT/$target_rel" >"$meta_current"
  stat -c '%a' "$generated_root/$target_rel" >"$meta_generated"

  if diff -u "$meta_current" "$meta_generated" >"$diff_file.metadata"; then
    rm -f "$meta_current" "$meta_generated" "$diff_file.metadata"
    printf -- "- %s metadata: clean\n" "$target_rel"
  else
    printf -- "- %s metadata: differs (diff: %s)\n" "$target_rel" "$diff_file.metadata"
    sed -n '1,200p' "$diff_file.metadata"
    status=1
  fi

  return "$status"
}

append_instruction_fragments() {
  local generated_root="$1"
  local manifest="$2"
  local target_rel="current-workspace/AGENTS.md"
  local target="$generated_root/$target_rel"
  local source
  local first=1
  local fragments=(
    "core/AGENTS.contract.md"
    "workspaces/detection-platform-metal/AGENTS.overlay.md"
    "workspaces/detection-platform-metal/AGENTS.references.md"
  )

  mkdir -p "$(dirname "$target")"
  : >"$target"
  for source in "${fragments[@]}"; do
    if [ ! -f "$ROOT/$source" ]; then
      echo "missing instruction source: $source" >&2
      return 1
    fi
    if [ "$first" -eq 0 ]; then
      printf '\n' >>"$target"
    fi
    cat "$ROOT/$source" >>"$target"
    first=0
    printf '%s\t%s\tinstruction-fragment\n' "$source" "$target_rel" >>"$manifest"
  done
  chmod --reference="$ROOT/$target_rel" "$target"
}

cmd="${1:-}"
case "$cmd" in
  dry-run)
    shift
    out_dir=""
    keep=0
    mode="all"

    while [ "$#" -gt 0 ]; do
      case "$1" in
        --mode)
          if [ "$#" -lt 2 ]; then
            echo "--mode requires all, compatibility, or instructions" >&2
            exit 2
          fi
          mode="$2"
          case "$mode" in
            all|compatibility|instructions) ;;
            *)
              echo "--mode requires all, compatibility, or instructions" >&2
              exit 2
              ;;
          esac
          shift 2
          ;;
        --out)
          if [ "$#" -lt 2 ]; then
            echo "--out requires a directory" >&2
            exit 2
          fi
          out_dir="$2"
          shift 2
          ;;
        --keep)
          keep=1
          shift
          ;;
        -h|--help)
          usage
          exit 0
          ;;
        *)
          usage >&2
          exit 2
          ;;
      esac
    done

    temp_created=0
    if [ -z "$out_dir" ]; then
      out_dir="$(mktemp -d "${TMPDIR:-/tmp}/workspace-control-render.XXXXXX")"
      temp_created=1
    else
      mkdir -p "$out_dir"
      out_dir="$(cd "$out_dir" && pwd)"
    fi

    cleanup() {
      if [ "$temp_created" -eq 1 ] && [ "$keep" -ne 1 ]; then
        rm -rf "$out_dir"
      fi
    }
    trap cleanup EXIT

    generated_root="$out_dir/rendered"
    diff_dir="$out_dir/diffs"
    manifest="$out_dir/manifest.tsv"
    rm -rf "$generated_root" "$diff_dir"
    mkdir -p "$generated_root" "$diff_dir"

    {
      printf 'source\ttarget\tmode\n'
    } >"$manifest"

    if [ "$mode" = "all" ] || [ "$mode" = "compatibility" ]; then
      printf 'current-workspace\tcurrent-workspace\tcompatibility-copy\n' >>"$manifest"
      printf 'agent-skills/skills\tagent-skills/skills\tcompatibility-copy\n' >>"$manifest"
      copy_tree "current-workspace" "current-workspace" "$generated_root"
      copy_tree "agent-skills/skills" "agent-skills/skills" "$generated_root"
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "instructions" ]; then
      append_instruction_fragments "$generated_root" "$manifest"
    fi

    echo "# Render Dry Run"
    echo "Root: $ROOT"
    echo "Mode: $mode"
    echo "Generated root: $generated_root"
    echo "Manifest: $manifest"
    echo

    echo "## Selected Sources"
    if [ "$mode" = "all" ] || [ "$mode" = "compatibility" ]; then
      echo "- current-workspace/ -> current-workspace/"
      echo "- agent-skills/skills/ -> agent-skills/skills/"
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "instructions" ]; then
      echo "- core/AGENTS.contract.md -> current-workspace/AGENTS.md"
      echo "- workspaces/detection-platform-metal/AGENTS.overlay.md -> current-workspace/AGENTS.md"
      echo "- workspaces/detection-platform-metal/AGENTS.references.md -> current-workspace/AGENTS.md"
    fi
    echo

    echo "## Source Files"
    if [ "$mode" = "all" ] || [ "$mode" = "compatibility" ]; then
      while IFS= read -r file; do
        printf -- "- current-workspace/%s\n" "$file"
      done < <(rel_files "current-workspace")
      while IFS= read -r file; do
        printf -- "- agent-skills/skills/%s\n" "$file"
      done < <(rel_files "agent-skills/skills")
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "instructions" ]; then
      echo "- core/AGENTS.contract.md"
      echo "- workspaces/detection-platform-metal/AGENTS.overlay.md"
      echo "- workspaces/detection-platform-metal/AGENTS.references.md"
    fi
    echo

    echo "## Target Diffs"
    status=0
    if [ "$mode" = "all" ] || [ "$mode" = "compatibility" ]; then
      compare_tree "current-workspace" "$generated_root" "$diff_dir" || status=1
      compare_tree "agent-skills/skills" "$generated_root" "$diff_dir" || status=1
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "instructions" ]; then
      compare_file "current-workspace/AGENTS.md" "$generated_root" "$diff_dir" || status=1
    fi
    echo

    echo "## Follow-Up Validation"
    cat <<'COMMANDS'
- git diff --check
- git diff --cached --check
- git show --check --oneline HEAD
- git diff --check origin/main..HEAD
- ./tools/check-sensitive-content .
- ./tools/knowledgectl lint
- SKILLCTL_CANONICAL_DIR=/workspace/workspace-control/agent-skills/skills /workspace/tools/skills/skillctl validate
COMMANDS

    if [ "$status" -eq 0 ]; then
      echo
      echo "render_dry_run: clean"
    else
      echo
      echo "render_dry_run: differences found"
    fi

    exit "$status"
    ;;
  -h|--help|"")
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
