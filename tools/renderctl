#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if ROOT="$(git -C "$SCRIPT_DIR/.." rev-parse --show-toplevel 2>/dev/null)"; then
  :
else
  ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
fi

usage() {
  cat <<'USAGE'
usage:
  tools/renderctl dry-run [--mode all|compatibility|instructions|skills|providers|live-check] [--live-root <dir>] [--out <dir>] [--keep]

Render the current workspace-control compatibility outputs into a generated
tree and diff them against the checked-in live-compatible sources.

This is intentionally conservative. The default mode checks checked-in
compatibility outputs plus draft instruction, skill, and provider composition.
It never writes to the live workspace.
USAGE
}

rel_files() {
  local rel="$1"
  find "$ROOT/$rel" -type f \
    ! -path '*/.DS_Store' \
    -printf '%P\n' | sort
}

rel_skill_files() {
  local rel="$1"
  find "$ROOT/$rel" -mindepth 2 -type f \
    ! -path '*/.DS_Store' \
    -printf '%P\n' | sort
}

copy_tree() {
  local source_rel="$1"
  local target_rel="$2"
  local generated_root="$3"

  if [ ! -d "$ROOT/$source_rel" ]; then
    echo "missing source directory: $source_rel" >&2
    return 1
  fi

  mkdir -p "$generated_root/$(dirname "$target_rel")"
  rm -rf "$generated_root/$target_rel"
  mkdir -p "$generated_root/$target_rel"
  cp -a "$ROOT/$source_rel/." "$generated_root/$target_rel/"
}

compare_tree() {
  local target_rel="$1"
  local generated_root="$2"
  local diff_dir="$3"
  local diff_file="$diff_dir/${target_rel//\//__}.diff"
  local meta_current="$diff_dir/${target_rel//\//__}.current-metadata"
  local meta_generated="$diff_dir/${target_rel//\//__}.generated-metadata"
  local status=0

  if diff -ruN "$ROOT/$target_rel" "$generated_root/$target_rel" >"$diff_file"; then
    rm -f "$diff_file"
    printf -- "- %s content: clean\n" "$target_rel"
  else
    printf -- "- %s content: differs (diff: %s)\n" "$target_rel" "$diff_file"
    sed -n '1,200p' "$diff_file"
    status=1
  fi

  (
    cd "$ROOT/$target_rel"
    find . -type f -printf '%m\t%P\n' | sort
  ) >"$meta_current"
  (
    cd "$generated_root/$target_rel"
    find . -type f -printf '%m\t%P\n' | sort
  ) >"$meta_generated"

  if diff -u "$meta_current" "$meta_generated" >"$diff_file.metadata"; then
    rm -f "$meta_current" "$meta_generated" "$diff_file.metadata"
    printf -- "- %s metadata: clean\n" "$target_rel"
  else
    printf -- "- %s metadata: differs (diff: %s)\n" "$target_rel" "$diff_file.metadata"
    sed -n '1,200p' "$diff_file.metadata"
    status=1
  fi

  return "$status"
}

compare_file() {
  local target_rel="$1"
  local generated_root="$2"
  local diff_dir="$3"
  local diff_file="$diff_dir/${target_rel//\//__}.diff"
  local meta_current="$diff_dir/${target_rel//\//__}.current-metadata"
  local meta_generated="$diff_dir/${target_rel//\//__}.generated-metadata"
  local status=0

  if diff -u "$ROOT/$target_rel" "$generated_root/$target_rel" >"$diff_file"; then
    rm -f "$diff_file"
    printf -- "- %s content: clean\n" "$target_rel"
  else
    printf -- "- %s content: differs (diff: %s)\n" "$target_rel" "$diff_file"
    sed -n '1,200p' "$diff_file"
    status=1
  fi

  stat -c '%a' "$ROOT/$target_rel" >"$meta_current"
  stat -c '%a' "$generated_root/$target_rel" >"$meta_generated"

  if diff -u "$meta_current" "$meta_generated" >"$diff_file.metadata"; then
    rm -f "$meta_current" "$meta_generated" "$diff_file.metadata"
    printf -- "- %s metadata: clean\n" "$target_rel"
  else
    printf -- "- %s metadata: differs (diff: %s)\n" "$target_rel" "$diff_file.metadata"
    sed -n '1,200p' "$diff_file.metadata"
    status=1
  fi

  return "$status"
}

metadata_for_tree() {
  local path="$1"
  local profile="$2"

  (
    cd "$path"
    case "$profile" in
      skill-mirror)
        find . -type f \
          ! -name '.skillctl-managed' \
          -printf '%m\t%P\n' | sort
        ;;
      tools)
        find . -type f \
          ! -path '*/__pycache__/*' \
          ! -name '*.pyc' \
          -printf '%m\t%P\n' | sort
        ;;
      none)
        find . -type f -printf '%m\t%P\n' | sort
        ;;
      *)
        echo "unknown metadata profile: $profile" >&2
        return 1
        ;;
    esac
  )
}

compare_live_tree() {
  local source_rel="$1"
  local target_rel="$2"
  local live_root="$3"
  local diff_dir="$4"
  local profile="$5"
  local label="live/$target_rel"
  local diff_key="${label//\//__}"
  local diff_file="$diff_dir/$diff_key.diff"
  local meta_source="$diff_dir/$diff_key.source-metadata"
  local meta_live="$diff_dir/$diff_key.live-metadata"
  local source_path="$ROOT/$source_rel"
  local target_path="$live_root/$target_rel"
  local diff_args=(-ruN)
  local status=0

  if [ ! -d "$source_path" ]; then
    echo "missing live-check source directory: $source_rel" >&2
    return 1
  fi
  if [ ! -d "$target_path" ]; then
    echo "missing live-check target directory: $target_path" >&2
    return 1
  fi

  case "$profile" in
    skill-mirror)
      diff_args+=(-x '.skillctl-managed')
      ;;
    tools)
      diff_args+=(-x '__pycache__' -x '*.pyc')
      ;;
    none) ;;
    *)
      echo "unknown live-check profile: $profile" >&2
      return 1
      ;;
  esac

  if diff "${diff_args[@]}" "$source_path" "$target_path" >"$diff_file"; then
    rm -f "$diff_file"
    printf -- "- %s content: clean\n" "$label"
  else
    printf -- "- %s content: differs (diff: %s)\n" "$label" "$diff_file"
    sed -n '1,200p' "$diff_file"
    status=1
  fi

  metadata_for_tree "$source_path" "$profile" >"$meta_source"
  metadata_for_tree "$target_path" "$profile" >"$meta_live"

  if diff -u "$meta_source" "$meta_live" >"$diff_file.metadata"; then
    rm -f "$meta_source" "$meta_live" "$diff_file.metadata"
    printf -- "- %s metadata: clean\n" "$label"
  else
    printf -- "- %s metadata: differs (diff: %s)\n" "$label" "$diff_file.metadata"
    sed -n '1,200p' "$diff_file.metadata"
    status=1
  fi

  return "$status"
}

compare_live_file() {
  local source_rel="$1"
  local target_rel="$2"
  local live_root="$3"
  local diff_dir="$4"
  local label="live/$target_rel"
  local diff_key="${label//\//__}"
  local diff_file="$diff_dir/$diff_key.diff"
  local meta_source="$diff_dir/$diff_key.source-metadata"
  local meta_live="$diff_dir/$diff_key.live-metadata"
  local source_path="$ROOT/$source_rel"
  local target_path="$live_root/$target_rel"
  local status=0

  if [ ! -f "$source_path" ]; then
    echo "missing live-check source file: $source_rel" >&2
    return 1
  fi
  if [ ! -f "$target_path" ]; then
    echo "missing live-check target file: $target_path" >&2
    return 1
  fi

  if diff -u "$source_path" "$target_path" >"$diff_file"; then
    rm -f "$diff_file"
    printf -- "- %s content: clean\n" "$label"
  else
    printf -- "- %s content: differs (diff: %s)\n" "$label" "$diff_file"
    sed -n '1,200p' "$diff_file"
    status=1
  fi

  stat -c '%a' "$source_path" >"$meta_source"
  stat -c '%a' "$target_path" >"$meta_live"

  if diff -u "$meta_source" "$meta_live" >"$diff_file.metadata"; then
    rm -f "$meta_source" "$meta_live" "$diff_file.metadata"
    printf -- "- %s metadata: clean\n" "$label"
  else
    printf -- "- %s metadata: differs (diff: %s)\n" "$label" "$diff_file.metadata"
    sed -n '1,200p' "$diff_file.metadata"
    status=1
  fi

  return "$status"
}

append_instruction_fragments() {
  local generated_root="$1"
  local manifest="$2"
  local target_rel="current-workspace/AGENTS.md"
  local target="$generated_root/$target_rel"
  local source
  local first=1
  local fragments=(
    "core/AGENTS.contract.md"
    "workspaces/detection-platform-metal/AGENTS.overlay.md"
    "workspaces/detection-platform-metal/AGENTS.references.md"
  )

  mkdir -p "$(dirname "$target")"
  : >"$target"
  for source in "${fragments[@]}"; do
    if [ ! -f "$ROOT/$source" ]; then
      echo "missing instruction source: $source" >&2
      return 1
    fi
    if [ "$first" -eq 0 ]; then
      printf '\n' >>"$target"
    fi
    cat "$ROOT/$source" >>"$target"
    first=0
    printf '%s\t%s\tinstruction-fragment\n' "$source" "$target_rel" >>"$manifest"
  done
  chmod --reference="$ROOT/$target_rel" "$target"
}

copy_skill_layer() {
  local source_rel="$1"
  local target_rel="$2"
  local generated_root="$3"
  local manifest="$4"
  local source_dir="$ROOT/$source_rel"
  local skill_path
  local skill_name

  if [ ! -d "$source_dir" ]; then
    echo "missing skill source directory: $source_rel" >&2
    return 1
  fi

  mkdir -p "$generated_root/$target_rel"
  while IFS= read -r skill_path; do
    skill_name="$(basename "$skill_path")"
    if [ -e "$generated_root/$target_rel/$skill_name" ]; then
      echo "duplicate generated skill: $skill_name" >&2
      return 1
    fi
    cp -a "$skill_path" "$generated_root/$target_rel/$skill_name"
    printf '%s/%s\t%s/%s\tskill-layer\n' "$source_rel" "$skill_name" "$target_rel" "$skill_name" >>"$manifest"
  done < <(find "$source_dir" -mindepth 1 -maxdepth 1 -type d | sort)
}

copy_provider_file() {
  local source_rel="$1"
  local target_rel="$2"
  local generated_root="$3"
  local manifest="$4"
  local render_mode="${5:-provider-adapter}"

  if [ ! -f "$ROOT/$source_rel" ]; then
    echo "missing provider source: $source_rel" >&2
    return 1
  fi
  if [ ! -f "$ROOT/$target_rel" ]; then
    echo "missing provider target: $target_rel" >&2
    return 1
  fi

  mkdir -p "$generated_root/$(dirname "$target_rel")"
  cp -a "$ROOT/$source_rel" "$generated_root/$target_rel"
  printf '%s\t%s\t%s\n' "$source_rel" "$target_rel" "$render_mode" >>"$manifest"
}

render_provider_adapters() {
  local generated_root="$1"
  local manifest="$2"

  copy_provider_file \
    "providers/claude/config/claude.settings.json" \
    "current-workspace/config/claude.settings.json" \
    "$generated_root" \
    "$manifest"
  copy_provider_file \
    "providers/claude/config/mcp.json" \
    "current-workspace/config/mcp.json" \
    "$generated_root" \
    "$manifest"
  copy_provider_file \
    "providers/codex/config/codex.config.toml" \
    "current-workspace/config/codex.config.toml" \
    "$generated_root" \
    "$manifest"
  copy_provider_file \
    "providers/pi/config/settings.example.json" \
    ".pi/settings.example.json" \
    "$generated_root" \
    "$manifest"
  copy_provider_file \
    "providers/claude/references/call-a-friend-commands.md" \
    "providers/claude/references/call-a-friend-commands.md" \
    "$generated_root" \
    "$manifest" \
    "provider-reference"
  copy_provider_file \
    "providers/codex/references/call-a-friend-commands.md" \
    "providers/codex/references/call-a-friend-commands.md" \
    "$generated_root" \
    "$manifest" \
    "provider-reference"
}

cmd="${1:-}"
case "$cmd" in
  dry-run)
    shift
    out_dir=""
    keep=0
    mode="all"
    live_root="/workspace"

    while [ "$#" -gt 0 ]; do
      case "$1" in
        --mode)
          if [ "$#" -lt 2 ]; then
            echo "--mode requires all, compatibility, instructions, skills, providers, or live-check" >&2
            exit 2
          fi
          mode="$2"
          case "$mode" in
            all|compatibility|instructions|skills|providers|live-check) ;;
            *)
              echo "--mode requires all, compatibility, instructions, skills, providers, or live-check" >&2
              exit 2
              ;;
          esac
          shift 2
          ;;
        --live-root)
          if [ "$#" -lt 2 ]; then
            echo "--live-root requires a directory" >&2
            exit 2
          fi
          live_root="$2"
          shift 2
          ;;
        --out)
          if [ "$#" -lt 2 ]; then
            echo "--out requires a directory" >&2
            exit 2
          fi
          out_dir="$2"
          shift 2
          ;;
        --keep)
          keep=1
          shift
          ;;
        -h|--help)
          usage
          exit 0
          ;;
        *)
          usage >&2
          exit 2
          ;;
      esac
    done

    temp_created=0
    if [ -z "$out_dir" ]; then
      out_dir="$(mktemp -d "${TMPDIR:-/tmp}/workspace-control-render.XXXXXX")"
      temp_created=1
    else
      mkdir -p "$out_dir"
      out_dir="$(cd "$out_dir" && pwd)"
    fi

    cleanup() {
      if [ "$temp_created" -eq 1 ] && [ "$keep" -ne 1 ]; then
        rm -rf "$out_dir"
      fi
    }
    trap cleanup EXIT

    generated_root="$out_dir/rendered"
    diff_dir="$out_dir/diffs"
    manifest="$out_dir/manifest.tsv"
    rm -rf "$generated_root" "$diff_dir"
    mkdir -p "$generated_root" "$diff_dir"

    {
      printf 'source\ttarget\tmode\n'
    } >"$manifest"

    if [ "$mode" = "all" ] || [ "$mode" = "compatibility" ]; then
      printf 'current-workspace\tcurrent-workspace\tcompatibility-copy\n' >>"$manifest"
      printf 'agent-skills/skills\tagent-skills/skills\tcompatibility-copy\n' >>"$manifest"
      copy_tree "current-workspace" "current-workspace" "$generated_root"
      copy_tree "agent-skills/skills" "agent-skills/skills" "$generated_root"
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "instructions" ]; then
      append_instruction_fragments "$generated_root" "$manifest"
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "skills" ]; then
      rm -rf "$generated_root/agent-skills/skills"
      mkdir -p "$generated_root/agent-skills/skills"
      copy_skill_layer "core/skills" "agent-skills/skills" "$generated_root" "$manifest"
      copy_skill_layer "workspaces/detection-platform-metal/skills" "agent-skills/skills" "$generated_root" "$manifest"
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "providers" ]; then
      render_provider_adapters "$generated_root" "$manifest"
    fi

    echo "# Render Dry Run"
    echo "Root: $ROOT"
    echo "Mode: $mode"
    if [ "$mode" = "live-check" ]; then
      echo "Live root: $live_root"
    fi
    echo "Generated root: $generated_root"
    echo "Manifest: $manifest"
    echo

    echo "## Selected Sources"
    if [ "$mode" = "all" ] || [ "$mode" = "compatibility" ]; then
      echo "- current-workspace/ -> current-workspace/"
      echo "- agent-skills/skills/ -> agent-skills/skills/"
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "instructions" ]; then
      echo "- core/AGENTS.contract.md -> current-workspace/AGENTS.md"
      echo "- workspaces/detection-platform-metal/AGENTS.overlay.md -> current-workspace/AGENTS.md"
      echo "- workspaces/detection-platform-metal/AGENTS.references.md -> current-workspace/AGENTS.md"
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "skills" ]; then
      echo "- core/skills/<skill>/ -> agent-skills/skills/<skill>/"
      echo "- workspaces/detection-platform-metal/skills/<skill>/ -> agent-skills/skills/<skill>/"
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "providers" ]; then
      echo "- providers/claude/config/claude.settings.json -> current-workspace/config/claude.settings.json"
      echo "- providers/claude/config/mcp.json -> current-workspace/config/mcp.json"
      echo "- providers/codex/config/codex.config.toml -> current-workspace/config/codex.config.toml"
      echo "- providers/pi/config/settings.example.json -> .pi/settings.example.json"
      echo "- providers/claude/references/call-a-friend-commands.md -> providers/claude/references/call-a-friend-commands.md"
      echo "- providers/codex/references/call-a-friend-commands.md -> providers/codex/references/call-a-friend-commands.md"
    fi
    if [ "$mode" = "live-check" ]; then
      echo "- current-workspace/AGENTS.md -> $live_root/AGENTS.md"
      echo "- current-workspace/CLAUDE.md -> $live_root/CLAUDE.md"
      echo "- current-workspace/tools/ -> $live_root/tools/"
      echo "- agent-skills/skills/ -> $live_root/agent-skills/skills/"
      echo "- agent-skills/skills/ -> $live_root/.claude/skills/ (excluding .skillctl-managed)"
      echo "- agent-skills/skills/ -> $live_root/.agents/skills/ (excluding .skillctl-managed)"
    fi
    echo

    echo "## Source Files"
    if [ "$mode" = "all" ] || [ "$mode" = "compatibility" ]; then
      while IFS= read -r file; do
        printf -- "- current-workspace/%s\n" "$file"
      done < <(rel_files "current-workspace")
      while IFS= read -r file; do
        printf -- "- agent-skills/skills/%s\n" "$file"
      done < <(rel_files "agent-skills/skills")
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "instructions" ]; then
      echo "- core/AGENTS.contract.md"
      echo "- workspaces/detection-platform-metal/AGENTS.overlay.md"
      echo "- workspaces/detection-platform-metal/AGENTS.references.md"
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "skills" ]; then
      while IFS= read -r file; do
        printf -- "- core/skills/%s\n" "$file"
      done < <(rel_skill_files "core/skills")
      while IFS= read -r file; do
        printf -- "- workspaces/detection-platform-metal/skills/%s\n" "$file"
      done < <(rel_skill_files "workspaces/detection-platform-metal/skills")
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "providers" ]; then
      echo "- providers/claude/config/claude.settings.json"
      echo "- providers/claude/config/mcp.json"
      echo "- providers/codex/config/codex.config.toml"
      echo "- providers/pi/config/settings.example.json"
      echo "- providers/claude/references/call-a-friend-commands.md"
      echo "- providers/codex/references/call-a-friend-commands.md"
    fi
    if [ "$mode" = "live-check" ]; then
      echo "- current-workspace/AGENTS.md"
      echo "- current-workspace/CLAUDE.md"
      while IFS= read -r file; do
        printf -- "- current-workspace/tools/%s\n" "$file"
      done < <(rel_files "current-workspace/tools")
      while IFS= read -r file; do
        printf -- "- agent-skills/skills/%s\n" "$file"
      done < <(rel_files "agent-skills/skills")
    fi
    echo

    echo "## Target Diffs"
    status=0
    if [ "$mode" = "compatibility" ]; then
      compare_tree "current-workspace" "$generated_root" "$diff_dir" || status=1
      compare_tree "agent-skills/skills" "$generated_root" "$diff_dir" || status=1
    elif [ "$mode" = "all" ]; then
      compare_tree "current-workspace" "$generated_root" "$diff_dir" || status=1
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "instructions" ]; then
      compare_file "current-workspace/AGENTS.md" "$generated_root" "$diff_dir" || status=1
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "skills" ]; then
      compare_tree "agent-skills/skills" "$generated_root" "$diff_dir" || status=1
    fi
    if [ "$mode" = "all" ] || [ "$mode" = "providers" ]; then
      compare_file "current-workspace/config/claude.settings.json" "$generated_root" "$diff_dir" || status=1
      compare_file "current-workspace/config/mcp.json" "$generated_root" "$diff_dir" || status=1
      compare_file "current-workspace/config/codex.config.toml" "$generated_root" "$diff_dir" || status=1
      compare_file ".pi/settings.example.json" "$generated_root" "$diff_dir" || status=1
      compare_file "providers/claude/references/call-a-friend-commands.md" "$generated_root" "$diff_dir" || status=1
      compare_file "providers/codex/references/call-a-friend-commands.md" "$generated_root" "$diff_dir" || status=1
    fi
    if [ "$mode" = "live-check" ]; then
      compare_live_file "current-workspace/AGENTS.md" "AGENTS.md" "$live_root" "$diff_dir" || status=1
      compare_live_file "current-workspace/CLAUDE.md" "CLAUDE.md" "$live_root" "$diff_dir" || status=1
      compare_live_tree "current-workspace/tools" "tools" "$live_root" "$diff_dir" "tools" || status=1
      compare_live_tree "agent-skills/skills" "agent-skills/skills" "$live_root" "$diff_dir" "none" || status=1
      compare_live_tree "agent-skills/skills" ".claude/skills" "$live_root" "$diff_dir" "skill-mirror" || status=1
      compare_live_tree "agent-skills/skills" ".agents/skills" "$live_root" "$diff_dir" "skill-mirror" || status=1
    fi
    echo

    echo "## Follow-Up Validation"
    cat <<'COMMANDS'
- git diff --check
- git diff --cached --check
- git show --check --oneline HEAD
- git diff --check origin/main..HEAD
- ./tools/check-sensitive-content .
- ./tools/knowledgectl lint
- ./tools/renderctl dry-run --mode live-check (pre/post activation drift check; may be nonzero before activation)
- SKILLCTL_CANONICAL_DIR=/workspace/workspace-control/agent-skills/skills /workspace/tools/skills/skillctl validate
- SKILLCTL_CANONICAL_DIR=<generated-root>/agent-skills/skills /workspace/tools/skills/skillctl validate
COMMANDS

    if [ "$status" -eq 0 ]; then
      echo
      echo "render_dry_run: clean"
    else
      echo
      echo "render_dry_run: differences found"
    fi

    exit "$status"
    ;;
  -h|--help|"")
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
