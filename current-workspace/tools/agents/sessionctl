                        code(session.get("resume_command")),
                        code(session.get("transcript")),
                        md_link("resume.md", session["resume_path"]),
                    ]
                )
                + " |"
            )
    else:
        lines.append("|  |  |  |  |  |  |  |  |")

    lines.extend(
        [
            "",
            "## Busy Dirs Missing Resume",
            "",
        ]
    )
    if snapshot["missing_resume"]:
        lines.extend(f"- `{task}`" for task in snapshot["missing_resume"])
    else:
        lines.append("- None")

    lines.extend(["", "## Resume Warnings", ""])
    if snapshot["warnings"]:
        for warning in snapshot["warnings"]:
            lines.append(f"- `{warning['task']}`: {warning['warning']} ({warning['resume_path']})")
    else:
        lines.append("- None")

    lines.extend(
        [
            "",
            "## Recovery Workflow",
            "",
            "1. Read `/workspace/detection-platform-metal-work/ACTIVE.md`.",
            "2. Read this generated file for the global session view.",
            "3. Open the relevant task-local `resume.md` for detailed next steps.",
            "4. Recreate tmux windows from the recorded resume commands, always starting from `/workspace`.",
        ]
    )
    return "\n".join(lines) + "\n"


def write_index(snapshot: dict, markdown_path: Path = SESSIONS_FILE, json_path: Path = SESSIONS_JSON) -> None:
    markdown_path.write_text(render_sessions_markdown(snapshot))
    json_path.parent.mkdir(parents=True, exist_ok=True)
    json_path.write_text(json.dumps(snapshot, indent=2, sort_keys=True) + "\n")


def cmd_init(args: argparse.Namespace) -> None:
    path = ensure_resume(
        args.task,
        worktree=args.worktree,
        branch=args.branch,
        pr=args.pr,
        gateway=args.gateway,
        note=args.note,
    )
    print(path)


def cmd_record(args: argparse.Namespace) -> None:
    transcript = args.transcript
    if not transcript and UUID_RE.fullmatch(args.session_id):
        transcript = transcript_for(args.provider, args.session_id)
    path = record_session(
        args.task,
        provider=args.provider,
        role=args.role,
        session_id=args.session_id,
        resume_command=args.resume_command,
        tmux=args.tmux,
        status=args.status,
        transcript=transcript,
        notes=args.notes,
        worktree=args.worktree,
        branch=args.branch,
        pr=args.pr,
        gateway=args.gateway,
    )
    print(path)


def cmd_detect(args: argparse.Namespace) -> None:
    detected = detect_live()
    if args.json:
        print(json.dumps(detected, indent=2, sort_keys=True))
        return
    if not detected:
        print("No live Claude/Codex resumed sessions detected from tmux process args.")
        return
    print("Tmux\tProvider\tSession ID\tSource\tCWD\tTranscript")
    for row in detected:
        print(
            f"{row['tmux']}\t{row['provider']}\t{row['session_id']}\t{row['source']}\t{row['cwd']}\t{row['transcript']}"
        )


def cmd_index(args: argparse.Namespace) -> None:
    snapshot = build_snapshot()
    markdown = render_sessions_markdown(snapshot)
    if args.stdout:
        print(markdown, end="")
        return
    write_index(snapshot, markdown_path=Path(args.output), json_path=Path(args.json_output))
    print(args.output)
    print(args.json_output)


def cmd_reconcile(args: argparse.Namespace) -> None:
    created = []
    normalized = []
    for path in busy_tasks():
        resume = path / "resume.md"
        if not resume.exists():
            ensure_resume(
                str(path),
                note=(
                    "No active agent sessions recorded yet. If a live pane owns this task, "
                    "record it with `/workspace/tools/agents/sessionctl record`."
                ),
            )
            created.append(str(resume))
        elif args.normalize and normalize_resume(resume):
            normalized.append(str(resume))

    snapshot = build_snapshot()
    write_index(snapshot, markdown_path=Path(args.output), json_path=Path(args.json_output))

    print(f"created_resume_files={len(created)}")
    for path in created:
        print(f"created {path}")
    print(f"normalized_resume_files={len(normalized)}")
    for path in normalized:
        print(f"normalized {path}")
    print(f"wrote {args.output}")
    print(f"wrote {args.json_output}")


def cmd_transcript(args: argparse.Namespace) -> None:
    path = transcript_for(args.provider, args.session_id)
    if not path:
        die(f"no transcript found for {args.provider} session {args.session_id}")
    print(path)


def cmd_codex_token(args: argparse.Namespace) -> None:
    deadline = time.time() + args.wait
    matches: list[tuple[str, str]] = []
    while True:
        matches = find_codex_token(args.token)
        if matches:
            break
        if args.wait <= 0 or time.time() >= deadline:
            break
        time.sleep(2)
    if not matches:
        die(f"no Codex transcript found containing token: {args.token}")
    for session_id, path in matches:
        print(f"{session_id}\t{path}")


def cmd_launch_claude(args: argparse.Namespace) -> None:
    session_id = args.session_id or str(uuid.uuid4())
    claude_args = ["claude-yolo", "--session-id", session_id]
    if args.name:
        claude_args.extend(["--name", args.name])
    command = "bash -ic " + shlex.quote("cd /workspace && " + " ".join(shlex.quote(a) for a in claude_args))
    resume_command = f"cd /workspace && claude-yolo --resume {session_id}"
    if args.dry_run:
        print(command)
        print(resume_command)
        return
    else:
        run(["tmux", "new-window", "-d", "-t", args.tmux_target, "-n", args.window, command])
    path = record_session(
        args.task,
        provider="Claude",
        role=args.role,
        session_id=session_id,
        resume_command=resume_command,
        tmux=f"{args.tmux_target}{args.window}",
        status="active" if not args.dry_run else "planned",
        transcript=transcript_for("claude", session_id),
        notes=args.notes,
    )
    print(path)


def cmd_launch_codex(args: argparse.Namespace) -> None:
    token = args.token or f"agent-session:{uuid.uuid4()}"
    prompt = args.prompt or (
        f"Workspace session tracking token: {token}\n\n"
        "Before doing task work, acknowledge this token in one short sentence, then wait for task-specific instructions."
    )
    command = "cd /workspace && codex --yolo -C /workspace " + shlex.quote(prompt)
    if args.dry_run:
        print(command)
        print(token)
        return

    run(["tmux", "new-window", "-d", "-t", args.tmux_target, "-n", args.window, command])
    session_id = ""
    transcript = ""
    deadline = time.time() + args.wait
    while time.time() <= deadline:
        matches = find_codex_token(token)
        if matches and matches[0][0]:
            session_id, transcript = matches[0]
            break
        time.sleep(2)

    if session_id:
        resume_command = f"cd /workspace && codex --yolo resume {session_id}"
        status = "active"
        notes = args.notes or f"Codex ID discovered from tracking token `{token}`."
    else:
        session_id = f"pending:{token}"
        resume_command = f"pending: /workspace/tools/agents/sessionctl codex-id-for-token {shlex.quote(token)}"
        status = "pending-id"
        notes = args.notes or f"Temporary row; replace after Codex transcript contains tracking token `{token}`."

    path = record_session(
        args.task,
        provider="Codex",
        role=args.role,
        session_id=session_id,
        resume_command=resume_command,
        tmux=f"{args.tmux_target}{args.window}",
        status=status,
        transcript=transcript,
        notes=notes,
    )
    print(path)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Record and recover Claude/Codex session IDs for workspace tasks.")
    sub = parser.add_subparsers(dest="command", required=True)

    init = sub.add_parser("init", help="Create busy/<task>/resume.md if missing")
    init.add_argument("task")
    init.add_argument("--worktree", default="")
    init.add_argument("--branch", default="")
    init.add_argument("--pr", default="")
    init.add_argument("--gateway", default="")
    init.add_argument("--note", default="")
    init.set_defaults(func=cmd_init)

    record = sub.add_parser("record", help="Add or update one session row in resume.md")
    record.add_argument("task")
    record.add_argument("--provider", required=True, choices=["Claude", "Codex", "claude", "codex"])
    record.add_argument("--role", required=True)
    record.add_argument("--session-id", required=True)
    record.add_argument("--resume-command", required=True)
    record.add_argument("--tmux", default="")
    record.add_argument("--status", default="active")
    record.add_argument("--transcript", default="")
    record.add_argument("--notes", default="")
    record.add_argument("--worktree", default="")
    record.add_argument("--branch", default="")
    record.add_argument("--pr", default="")
    record.add_argument("--gateway", default="")
    record.set_defaults(func=cmd_record)

    detect = sub.add_parser("detect", help="Detect live resumed Claude/Codex sessions from tmux process args")
    detect.add_argument("--json", action="store_true")
    detect.set_defaults(func=cmd_detect)

    index = sub.add_parser("index", help="Generate the central SESSIONS.md lookup from task resume files and live tmux state")
    index.add_argument("--stdout", action="store_true", help="Print markdown instead of writing files")
    index.add_argument("--output", default=str(SESSIONS_FILE))
    index.add_argument("--json-output", default=str(SESSIONS_JSON))
    index.set_defaults(func=cmd_index)

    reconcile = sub.add_parser("reconcile", help="Create missing resume.md files, normalize old ones, and regenerate SESSIONS.md")
    reconcile.add_argument("--no-normalize", dest="normalize", action="store_false", help="Do not normalize nonstandard resume.md files")
    reconcile.add_argument("--output", default=str(SESSIONS_FILE))
    reconcile.add_argument("--json-output", default=str(SESSIONS_JSON))
    reconcile.set_defaults(func=cmd_reconcile, normalize=True)

    transcript = sub.add_parser("transcript", help="Print transcript path for a known session ID")
    transcript.add_argument("provider", choices=["Claude", "Codex", "claude", "codex"])
    transcript.add_argument("session_id")
    transcript.set_defaults(func=cmd_transcript)

    codex_token = sub.add_parser("codex-id-for-token", help="Find a Codex session ID by a unique prompt token")
    codex_token.add_argument("token")
    codex_token.add_argument("--wait", type=int, default=0, help="Seconds to wait for a transcript to appear")
    codex_token.set_defaults(func=cmd_codex_token)

    launch_claude = sub.add_parser("launch-claude", help="Launch Claude in tmux with a preassigned session ID and record it")
    launch_claude.add_argument("task")
    launch_claude.add_argument("window")
    launch_claude.add_argument("--role", required=True)
    launch_claude.add_argument("--session-id", default="")
    launch_claude.add_argument("--name", default="")
    launch_claude.add_argument("--notes", default="")
    launch_claude.add_argument("--tmux-target", default="0:")
    launch_claude.add_argument("--dry-run", action="store_true")
    launch_claude.set_defaults(func=cmd_launch_claude)

    launch_codex = sub.add_parser("launch-codex", help="Launch Codex in tmux with a tracking token and record the discovered ID")
    launch_codex.add_argument("task")
    launch_codex.add_argument("window")
    launch_codex.add_argument("--role", required=True)
    launch_codex.add_argument("--token", default="")
    launch_codex.add_argument("--prompt", default="")
    launch_codex.add_argument("--notes", default="")
    launch_codex.add_argument("--tmux-target", default="0:")
    launch_codex.add_argument("--wait", type=int, default=60)
    launch_codex.add_argument("--dry-run", action="store_true")
    launch_codex.set_defaults(func=cmd_launch_codex)

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
