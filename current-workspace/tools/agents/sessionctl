#!/usr/bin/env python3
"""Workspace helper for recording Claude/Codex session resume metadata."""

from __future__ import annotations

import argparse
import json
import os
import re
import shlex
import subprocess
import sys
import time
import uuid
from pathlib import Path


ROOT = Path(os.environ.get("WORKSPACE_ROOT", "/workspace"))
WORK_ROOT = ROOT / "detection-platform-metal-work"
BUSY_ROOT = WORK_ROOT / "busy"
SESSIONS_FILE = WORK_ROOT / "SESSIONS.md"
SESSIONS_STATE_DIR = WORK_ROOT / ".sessions"
SESSIONS_JSON = SESSIONS_STATE_DIR / "index.json"
CLAUDE_PROJECTS = Path.home() / ".claude" / "projects"
CODEX_SESSIONS = Path.home() / ".codex" / "sessions"
UUID_RE = re.compile(
    r"\b[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\b"
)


def die(message: str) -> None:
    print(f"sessionctl: {message}", file=sys.stderr)
    raise SystemExit(2)


def run(args: list[str], *, check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(args, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=check)


def utc_now() -> str:
    return time.strftime("%Y-%m-%d %H:%M:%SZ", time.gmtime())


def task_dir(task: str) -> Path:
    path = Path(task)
    if path.is_absolute():
        return path
    return BUSY_ROOT / task


def resume_file(task: str) -> Path:
    return task_dir(task) / "resume.md"


def md(value: str | None) -> str:
    if not value:
        return ""
    return value.replace("\n", " ").replace("|", "\\|")


def code(value: str | None) -> str:
    if not value:
        return ""
    safe = md(value).replace("`", "\\`")
    return f"`{safe}`"


def ensure_resume(
    task: str,
    *,
    worktree: str = "",
    branch: str = "",
    pr: str = "",
    gateway: str = "",
    note: str = "",
) -> Path:
    tdir = task_dir(task)
    tdir.mkdir(parents=True, exist_ok=True)
    path = tdir / "resume.md"
    if path.exists():
        return path

    display_task = tdir.name
    text = f"""# Resume

Updated: {utc_now()}
Canonical cwd: /workspace

## Sessions

| Provider | Role | Session ID | Resume Command | Tmux | Status | Transcript | Notes |
|---|---|---|---|---|---|---|---|

## Work Context

- Task dir: `{tdir}`
- Worktree: `{worktree}`
- Branch: `{branch}`
- PR / issue: `{pr}`
- Gateway route: `{gateway}`

## Current State

- {note or f"Session metadata initialized for `{display_task}`."}

## Next Step

- Update this section before pausing or handing off the task.

## Stale Sessions

- None recorded.
"""
    path.write_text(text)
    return path


def replace_updated(text: str) -> str:
    return re.sub(r"^Updated: .*$", f"Updated: {utc_now()}", text, count=1, flags=re.MULTILINE)


def record_session(
    task: str,
    *,
    provider: str,
    role: str,
    session_id: str,
    resume_command: str,
    tmux: str = "",
    status: str = "active",
    transcript: str = "",
    notes: str = "",
    worktree: str = "",
    branch: str = "",
    pr: str = "",
    gateway: str = "",
) -> Path:
    if status != "pending-id" and not UUID_RE.fullmatch(session_id):
        die(f"session id is not a UUID: {session_id}")

    path = ensure_resume(task, worktree=worktree, branch=branch, pr=pr, gateway=gateway)
    text = path.read_text()
    text = replace_updated(text)
    row = (
        f"| {md(provider)} | {md(role)} | {code(session_id)} | {code(resume_command)} | "
        f"{code(tmux)} | {md(status)} | {code(transcript)} | {md(notes)} |"
    )

    lines = []
    for line in text.splitlines():
        if line.startswith("| ") and session_id in line:
            continue
        lines.append(line)
    text = "\n".join(lines) + "\n"

    marker = "|---|---|---|---|---|---|---|---|"
    if marker not in text:
        die(f"{path} does not contain the expected Sessions table")
    text = text.replace(marker, marker + "\n" + row, 1)
    path.write_text(text)
    return path


def transcript_for(provider: str, session_id: str) -> str:
    if provider.lower() == "claude":
        matches = sorted(CLAUDE_PROJECTS.glob(f"**/{session_id}.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
        return str(matches[0]) if matches else ""

    if provider.lower() == "codex":
        matches = sorted(CODEX_SESSIONS.glob(f"**/*{session_id}.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
        if matches:
            return str(matches[0])
        for path in CODEX_SESSIONS.glob("**/*.jsonl"):
            try:
                with path.open() as fh:
                    for line in fh:
                        if session_id in line:
                            return str(path)
            except OSError:
                continue
        return ""

    return ""


def parse_session_from_cmd(cmd: str) -> tuple[str, str, str] | None:
    try:
        parts = shlex.split(cmd)
    except ValueError:
        parts = cmd.split()

    if not parts:
        return None

    lower = [Path(p).name.lower() for p in parts]
    if any(p == "claude" for p in lower):
        for flag in ("--resume", "-r", "--session-id"):
            if flag in parts:
                idx = parts.index(flag)
                if idx + 1 < len(parts) and UUID_RE.fullmatch(parts[idx + 1]):
                    source = flag
                    return ("claude", parts[idx + 1], source)
        for part in parts:
            if part.startswith("--resume=") or part.startswith("--session-id="):
                value = part.split("=", 1)[1]
                if UUID_RE.fullmatch(value):
                    return ("claude", value, part.split("=", 1)[0])

    if any(p == "codex" for p in lower):
        for idx, part in enumerate(parts[:-1]):
            if part == "resume" and UUID_RE.fullmatch(parts[idx + 1]):
                return ("codex", parts[idx + 1], "resume")

    return None


def ps_rows() -> list[tuple[int, int, str]]:
    proc = run(["ps", "-eo", "pid=,ppid=,args="], check=False)
    rows: list[tuple[int, int, str]] = []
    for line in proc.stdout.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        parts = stripped.split(None, 2)
        if len(parts) < 3:
            continue
        try:
            rows.append((int(parts[0]), int(parts[1]), parts[2]))
        except ValueError:
            continue
    return rows


def tmux_panes() -> list[dict[str, str]]:
    proc = run(
        [
            "tmux",
            "list-panes",
            "-a",
            "-F",
            "#{session_name}\t#{window_index}\t#{window_name}\t#{pane_index}\t#{pane_pid}\t#{pane_current_path}",
        ],
        check=False,
    )
    panes = []
    for line in proc.stdout.splitlines():
        parts = line.split("\t")
        if len(parts) != 6:
            continue
        session, window, name, pane, pid, cwd = parts
        panes.append(
            {
                "target": f"{session}:{window}.{pane}",
                "window": f"{session}:{window}:{name}",
                "pane_pid": pid,
                "cwd": cwd,
            }
        )
    return panes


def descendants(pid: int, children: dict[int, list[tuple[int, str]]]) -> list[tuple[int, str]]:
    out: list[tuple[int, str]] = []
    stack = [pid]
    seen = set(stack)
    while stack:
        current = stack.pop()
        for child_pid, cmd in children.get(current, []):
            if child_pid in seen:
                continue
            seen.add(child_pid)
            out.append((child_pid, cmd))
            stack.append(child_pid)
    return out


def detect_live() -> list[dict[str, str]]:
    rows = ps_rows()
    children: dict[int, list[tuple[int, str]]] = {}
    pid_to_cmd: dict[int, str] = {}
    for pid, ppid, cmd in rows:
        pid_to_cmd[pid] = cmd
        children.setdefault(ppid, []).append((pid, cmd))

    detected: list[dict[str, str]] = []
    seen = set()
    for pane in tmux_panes():
        try:
            pane_pid = int(pane["pane_pid"])
        except ValueError:
            continue
        candidates = []
        if pane_pid in pid_to_cmd:
            candidates.append((pane_pid, pid_to_cmd[pane_pid]))
        candidates.extend(descendants(pane_pid, children))
        for child_pid, cmd in candidates:
            parsed = parse_session_from_cmd(cmd)
            if not parsed:
                continue
            provider, session_id, source = parsed
            key = (pane["target"], provider, session_id)
            if key in seen:
                continue
            seen.add(key)
            detected.append(
                {
                    "tmux": pane["window"],
                    "target": pane["target"],
                    "provider": provider,
                    "session_id": session_id,
                    "source": source,
                    "cwd": pane["cwd"],
                    "transcript": transcript_for(provider, session_id),
                    "command": cmd,
                }
            )
    return detected


def looks_like_agent_cmd(cmd: str) -> bool:
    try:
        parts = shlex.split(cmd)
    except ValueError:
        parts = cmd.split()
    names = [Path(part).name.lower() for part in parts]
    if any(name in {"claude", "claude-yolo", "codex"} for name in names):
        return True
    return "/codex" in cmd or " @openai/codex" in cmd


def detect_agent_panes_without_id() -> list[dict[str, str]]:
    rows = ps_rows()
    children: dict[int, list[tuple[int, str]]] = {}
    pid_to_cmd: dict[int, str] = {}
    for pid, ppid, cmd in rows:
        pid_to_cmd[pid] = cmd
        children.setdefault(ppid, []).append((pid, cmd))

    unknown = []
    for pane in tmux_panes():
        try:
            pane_pid = int(pane["pane_pid"])
        except ValueError:
            continue
        candidates = []
        if pane_pid in pid_to_cmd:
            candidates.append((pane_pid, pid_to_cmd[pane_pid]))
        candidates.extend(descendants(pane_pid, children))

        has_known_id = False
        first_agent_cmd = ""
        for _pid, cmd in candidates:
            if parse_session_from_cmd(cmd):
                has_known_id = True
                break
            if not first_agent_cmd and looks_like_agent_cmd(cmd):
                first_agent_cmd = cmd
        if first_agent_cmd and not has_known_id:
            unknown.append(
                {
                    "tmux": pane["window"],
                    "target": pane["target"],
                    "cwd": pane["cwd"],
                    "command": first_agent_cmd,
                }
            )
    return unknown


def find_codex_token(token: str) -> list[tuple[str, str]]:
    found = []
    for path in sorted(CODEX_SESSIONS.glob("**/*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True):
        token_seen = token in path.name
        session_id = ""
        try:
            with path.open(errors="replace") as fh:
                for line in fh:
                    if token in line:
                        token_seen = True
                    if not session_id:
                        try:
                            event = json.loads(line)
                        except json.JSONDecodeError:
                            continue
                        if event.get("type") == "session_meta":
                            payload = event.get("payload") or {}
                            session_id = payload.get("id") or ""
        except OSError:
            continue
        if not token_seen:
            continue
        found.append((session_id, str(path)))
    return found


def busy_tasks() -> list[Path]:
    if not BUSY_ROOT.exists():
        return []
    return sorted(path for path in BUSY_ROOT.iterdir() if path.is_dir())


def unescape_md(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == "`" and value[-1] == "`":
        value = value[1:-1]
    return value.replace("\\|", "|").replace("\\`", "`").strip()


def split_md_row(line: str) -> list[str]:
    line = line.strip()
    if line.startswith("|"):
        line = line[1:]
    if line.endswith("|"):
        line = line[:-1]

    cells: list[str] = []
    current = []
    escaped = False
    for char in line:
        if escaped:
            current.append("\\" + char if char not in "|`" else char)
            escaped = False
            continue
        if char == "\\":
            escaped = True
            continue
        if char == "|":
            cells.append(unescape_md("".join(current)))
            current = []
        else:
            current.append(char)
    if escaped:
        current.append("\\")
    cells.append(unescape_md("".join(current)))
    return cells


def parse_context_value(line: str) -> tuple[str, str] | None:
    match = re.match(r"^-\s+([^:]+):\s*(.*)$", line.strip())
    if not match:
        return None
    key = match.group(1).strip().lower()
    value = unescape_md(match.group(2).strip())
    return key, value


def parse_resume(path: Path) -> dict:
    text = path.read_text(errors="replace") if path.exists() else ""
    lines = text.splitlines()
    task = path.parent.name
    parsed = {
        "task": task,
        "resume_path": str(path),
        "updated": "",
        "canonical_cwd": "",
        "context": {
            "task_dir": str(path.parent),
            "worktree": "",
            "branch": "",
            "pr": "",
            "gateway": "",
        },
        "sessions": [],
        "warnings": [],
        "standard": False,
    }

    for line in lines:
        if line.startswith("Updated:"):
            parsed["updated"] = line.split(":", 1)[1].strip()
        elif line.startswith("Canonical cwd:"):
            parsed["canonical_cwd"] = line.split(":", 1)[1].strip()

    in_context = False
    for line in lines:
        if line.strip() == "## Work Context":
            in_context = True
            continue
        if in_context and line.startswith("## "):
            break
        if in_context:
            item = parse_context_value(line)
            if not item:
                continue
            key, value = item
            if key == "task dir":
                parsed["context"]["task_dir"] = value
            elif key == "worktree":
                parsed["context"]["worktree"] = value
            elif key == "branch":
                parsed["context"]["branch"] = value
            elif key in ("pr / issue", "pr", "issue"):
                parsed["context"]["pr"] = value
            elif key == "gateway route":
                parsed["context"]["gateway"] = value

    header_index = -1
    for idx, line in enumerate(lines):
        if line.strip().startswith("| Provider | Role | Session ID |"):
            header_index = idx
            break

    if header_index == -1:
        if text.strip():
            parsed["warnings"].append("resume.md is not in the standard session table format")
        return parsed

    parsed["standard"] = True
    for line in lines[header_index + 2 :]:
        stripped = line.strip()
        if not stripped or not stripped.startswith("|"):
            break
        cells = split_md_row(stripped)
        if len(cells) < 8:
            parsed["warnings"].append(f"could not parse session row: {stripped[:120]}")
            continue
        provider, role, session_id, resume_command, tmux, status, transcript, notes = cells[:8]
        if not session_id:
            continue
        parsed["sessions"].append(
            {
                "task": task,
                "resume_path": str(path),
                "provider": provider,
                "role": role,
                "session_id": session_id,
                "resume_command": resume_command,
                "tmux": tmux,
                "status": status,
                "transcript": transcript,
                "notes": notes,
                "context": parsed["context"],
                "updated": parsed["updated"],
                "canonical_cwd": parsed["canonical_cwd"],
            }
        )
    return parsed


def normalize_resume(path: Path) -> bool:
    parsed = parse_resume(path)
    if parsed["standard"]:
        return False
    old_text = path.read_text(errors="replace") if path.exists() else ""
    preserved = ""
    if old_text.strip():
        preserved = "\n## Previous Resume Notes\n\n"
        preserved += "\n".join(f"> {line}" if line else ">" for line in old_text.splitlines())
        preserved += "\n"
    text = f"""# Resume

Updated: {utc_now()}
Canonical cwd: /workspace

## Sessions

| Provider | Role | Session ID | Resume Command | Tmux | Status | Transcript | Notes |
|---|---|---|---|---|---|---|---|

## Work Context

- Task dir: `{path.parent}`
- Worktree: ``
- Branch: ``
- PR / issue: ``
- Gateway route: ``

## Current State

- Standard session metadata initialized for `{path.parent.name}`.

## Next Step

- Update this section before pausing or handing off the task.

## Stale Sessions

- None recorded.
{preserved}"""
    path.write_text(text)
    return True


def build_snapshot() -> dict:
    task_paths = busy_tasks()
    resume_paths = {path.parent.name: path for path in BUSY_ROOT.glob("*/resume.md")}
    parsed_resumes = [parse_resume(path) for path in sorted(resume_paths.values())]
    recorded_sessions = [session for resume in parsed_resumes for session in resume["sessions"]]
    live_sessions = detect_live()
    live_agent_panes_without_id = detect_agent_panes_without_id()

    recorded_by_id: dict[str, list[dict]] = {}
    for session in recorded_sessions:
        recorded_by_id.setdefault(session["session_id"].lower(), []).append(session)
    recorded_tmux = {
        session.get("tmux", "")
        for session in recorded_sessions
        if session.get("tmux") and UUID_RE.fullmatch(session.get("session_id", ""))
    }
    live_agent_panes_without_id = [
        pane for pane in live_agent_panes_without_id if pane.get("tmux") not in recorded_tmux
    ]

    live_by_id: dict[str, list[dict]] = {}
    for session in live_sessions:
        live_by_id.setdefault(session["session_id"].lower(), []).append(session)

    live_recorded = []
    recorded_not_live = []
    for session in recorded_sessions:
        live_matches = live_by_id.get(session["session_id"].lower(), [])
        if live_matches:
            for match in live_matches:
                enriched = dict(session)
                enriched["live"] = match
                live_recorded.append(enriched)
        else:
            recorded_not_live.append(session)

    live_unrecorded = []
    for session in live_sessions:
        if session["session_id"].lower() not in recorded_by_id:
            live_unrecorded.append(session)

    missing_resume = [path.name for path in task_paths if path.name not in resume_paths]
    warnings = []
    for resume in parsed_resumes:
        for warning in resume["warnings"]:
            warnings.append({"task": resume["task"], "resume_path": resume["resume_path"], "warning": warning})

    return {
        "generated_at": utc_now(),
        "busy_task_count": len(task_paths),
        "recorded_resume_count": len(resume_paths),
        "recorded_session_count": len(recorded_sessions),
        "live_detected_count": len(live_sessions),
        "live_agent_panes_without_id_count": len(live_agent_panes_without_id),
        "live_recorded_count": len(live_recorded),
        "recorded_not_live_count": len(recorded_not_live),
        "live_unrecorded_count": len(live_unrecorded),
        "missing_resume_count": len(missing_resume),
        "tasks": [path.name for path in task_paths],
        "missing_resume": missing_resume,
        "resumes": parsed_resumes,
        "recorded_sessions": recorded_sessions,
        "live_sessions": live_sessions,
        "live_agent_panes_without_id": live_agent_panes_without_id,
        "live_recorded": live_recorded,
        "recorded_not_live": recorded_not_live,
        "live_unrecorded": live_unrecorded,
        "warnings": warnings,
    }


def short(value: str, limit: int = 96) -> str:
    value = value or ""
    if len(value) <= limit:
        return value
    return value[: limit - 1] + "..."


def md_link(label: str, path: str) -> str:
    return f"[{md(label)}]({md(path)})"


